@page
@model GrahamSchoolAdminSystemWeb.Pages.account.change_passwordModel
@{
    ViewData["Title"] = "Change Password";
}
@section Sheets {
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <style>
        .change-pw-card {
            max-width: 560px;
            margin: 0 auto;
        }

        .pw-form-header {
            text-align: center;
            margin-bottom: var(--spacing-xl);
        }

        .pw-form-header .pw-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent-gold) 0%, #f5c842 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto var(--spacing-md);
            font-size: 1.75rem;
            color: var(--primary-navy);
            box-shadow: 0 4px 16px rgba(245, 183, 49, 0.35);
        }

        .pw-form-header h2 {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary-navy);
            margin-bottom: 0.25rem;
        }

        .pw-form-header p {
            color: var(--color-gray-500);
            font-size: 0.9rem;
        }

        .pw-user-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--color-gray-100);
            border-radius: 2rem;
            padding: 0.35rem 1rem;
            font-size: 0.85rem;
            color: var(--color-gray-600);
            margin-bottom: var(--spacing-lg);
        }

        .pw-user-badge i {
            color: var(--accent-sky);
        }

        .pw-field-group {
            margin-bottom: var(--spacing-lg);
        }

        .pw-field-group label {
            display: block;
            font-weight: 600;
            font-size: 0.875rem;
            color: var(--primary-navy);
            margin-bottom: 0.25rem;
        }

        .pw-field-group label i {
            margin-right: 0.35rem;
            font-size: 0.9rem;
        }

        .pw-input-wrap {
            position: relative;
        }

        .pw-input-wrap input {
            width: 100%;
            padding: 0.65rem 2.75rem 0.65rem 1rem;
            border: 2px solid var(--color-gray-200);
            border-radius: var(--border-radius-md);
            font-size: 0.95rem;
            transition: var(--transition-fast);
            background: var(--color-white);
        }

        .pw-input-wrap input:focus {
            outline: none;
            border-color: var(--accent-sky);
            box-shadow: 0 0 0 3px rgba(79, 200, 244, 0.15);
        }

        .pw-input-wrap .pw-toggle {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--color-gray-400);
            cursor: pointer;
            font-size: 1.1rem;
            padding: 0;
            line-height: 1;
        }

        .pw-input-wrap .pw-toggle:hover {
            color: var(--primary-navy);
        }

        .pw-requirements {
            background: var(--color-gray-50);
            border-radius: var(--border-radius-md);
            padding: var(--spacing-md);
            margin-bottom: var(--spacing-lg);
            border: 1px solid var(--color-gray-200);
        }

        .pw-requirements h6 {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--color-gray-500);
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .pw-requirements ul {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.3rem;
        }

        .pw-requirements li {
            font-size: 0.8rem;
            color: var(--color-gray-600);
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .pw-requirements li i {
            color: var(--accent-mint);
            font-size: 0.75rem;
        }

        .pw-actions {
            display: flex;
            gap: var(--spacing-md);
            margin-top: var(--spacing-xl);
        }

        .pw-actions .btn {
            flex: 1;
            padding: 0.7rem 1.5rem;
            font-weight: 600;
            border-radius: var(--border-radius-md);
            font-size: 0.95rem;
            transition: var(--transition-fast);
        }

        .pw-actions .btn-primary {
            background: var(--gradient-primary);
            border: none;
            color: var(--color-white);
        }

        .pw-actions .btn-primary:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-1px);
        }

        .pw-actions .btn-outline-secondary {
            border: 2px solid var(--color-gray-200);
            background: var(--color-white);
            color: var(--color-gray-600);
        }

        .pw-actions .btn-outline-secondary:hover {
            border-color: var(--color-gray-300);
            background: var(--color-gray-50);
        }

        .pw-divider {
            border: none;
            border-top: 1px solid var(--color-gray-200);
            margin: var(--spacing-lg) 0;
        }

        @@media (max-width: 576px) {
            .pw-requirements ul {
                grid-template-columns: 1fr;
            }

            .pw-actions {
                flex-direction: column;
            }
        }
    </style>
}

<div class="page-header">
    <div class="text-white">
        <h1><i class="bi bi-shield-lock"></i> Change Password</h1>
        <p class="text-white">Update your account password for security</p>
    </div>
</div>

<div class="page-content">
    <div class="change-pw-card">

        @if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong>Success!</strong> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i>
                <strong>Error!</strong> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="text-white">
                    <h2>Update Your Password</h2>
                    <p>Enter your current password and choose a new one</p>
                    @if (!string.IsNullOrEmpty(Model.UserEmail))
                    {
                        <div class="pw-user-badge">
                            <i class="bi bi-person-circle"></i> @Model.UserEmail
                        </div>
                    }
                </div>
            </div>
            <div class="card-body">
                <form method="post" id="changePasswordForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="pw-field-group">
                        <label for="CurrentPassword">
                            <i class="bi bi-lock-fill"></i> Current Password
                        </label>
                        <div class="pw-input-wrap">
                            <input asp-for="CurrentPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Enter your current password"
                                   autocomplete="current-password" />
                            <button type="button" class="pw-toggle" onclick="togglePwField(this)">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="pw-field-group">
                        <label for="NewPassword">
                            <i class="bi bi-key-fill"></i> New Password
                        </label>
                        <div class="pw-input-wrap">
                            <input asp-for="NewPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Enter your new password"
                                   autocomplete="new-password" />
                            <button type="button" class="pw-toggle" onclick="togglePwField(this)">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="pw-field-group">
                        <label for="ConfirmNewPassword">
                            <i class="bi bi-check-circle-fill"></i> Confirm New Password
                        </label>
                        <div class="pw-input-wrap">
                            <input asp-for="ConfirmNewPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Re-enter your new password"
                                   autocomplete="new-password" />
                            <button type="button" class="pw-toggle" onclick="togglePwField(this)">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="pw-requirements">
                        <h6><i class="bi bi-info-circle"></i> Password Requirements</h6>
                        <ul>
                            <li><i class="bi bi-check-circle-fill"></i> At least 6 characters</li>
                            <li><i class="bi bi-check-circle-fill"></i> At least one uppercase letter</li>
                            <li><i class="bi bi-check-circle-fill"></i> At least one lowercase letter</li>
                            <li><i class="bi bi-check-circle-fill"></i> At least one digit</li>
                        </ul>
                    </div>

                    <div class="pw-actions">
                        <a asp-page="/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-shield-check me-1"></i> Update Password
                        </button>
                    </div>
                </form>
            </div>
        </div>

        
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwField(btn) {
            var input = btn.previousElementSibling;
            var icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye-fill', 'bi-eye-slash-fill');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash-fill', 'bi-eye-fill');
            }
        }
    </script>
}
