@page
@model GrahamSchoolAdminSystemWeb.Pages.account.logoutModel
@{
    ViewData["Title"] = "Logging Out - Graham School Admin System";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/lib/twitter-bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <style>
        .logout-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1a2b6d 0%, #0b1437 100%);
        }

        .logout-card {
            background: white;
            border-radius: 16px;
            padding: 3rem;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0,0,0,.3);
            max-width: 400px;
            width: 90%;
        }

        .logout-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 1.5rem;
            background: linear-gradient(135deg, #f5b731 0%, #f39c12 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: white;
            animation: fadeIn 0.5s ease-in-out;
        }

        .logout-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0b1437;
            margin-bottom: 1rem;
        }

        .logout-message {
            color: #6c757d;
            margin-bottom: 2rem;
            font-size: 0.95rem;
        }

        .spinner-border-custom {
            width: 2rem;
            height: 2rem;
            border-width: 0.25rem;
            color: #f5b731;
            margin: 1rem auto;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(0.8);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .redirect-text {
            font-size: 0.85rem;
            color: #6c757d;
            margin-top: 1rem;
        }
    </style>
</head>
<body>
    <div class="logout-container">
        <div class="logout-card">
            <div class="logout-icon">
                <i class="bi bi-box-arrow-right"></i>
            </div>
            <h1 class="logout-title">Logging Out...</h1>
            <p class="logout-message">Please wait while we securely sign you out of the system.</p>
            
            <div class="spinner-border spinner-border-custom" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>

            <p class="redirect-text">
                <i class="bi bi-arrow-right-circle"></i> You will be redirected to the login page shortly
            </p>
        </div>
    </div>

    <script>
        // Auto-redirect after 2 seconds if page doesn't automatically redirect
        setTimeout(function() {
            window.location.href = '/account/login';
        }, 2000);
    </script>
</body>
</html>
