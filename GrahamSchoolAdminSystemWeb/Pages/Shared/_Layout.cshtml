<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Graham School Admin System</title>

    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/lib/twitter-bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Tangerine">
    @await RenderSectionAsync("Sheets", required: false)

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GrahamSchoolAdminSystemWeb.styles.css" asp-append-version="true" />
</head>
@inject IPermissionService PermissionService
@{
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var userInfo = currentUserId != null
        ? await PermissionService.GetUserDisplayInfoAsync(currentUserId)
        : new UserDisplayInfo();
    var userInitials = userInfo.Initials;
    var userDisplayName = userInfo.FullName;
    var userPosition = !string.IsNullOrEmpty(userInfo.PositionName) ? userInfo.PositionName : "Staff";
    var userRoleBadge = userInfo.IsAdmin ? "Admin" : userInfo.IsAccountant ? "Accountant" : userInfo.IsCashier ? "Cashier" : "Staff";
    var canReport = currentUserId != null && await PermissionService.UserHasPermissionAsync(User, SD.Permissions.REPORT);
}
<body>
    <nav id="sidebar">
        <div class="brand d-flex align-items-center">
            <div class="logo-icon8"><img src="~/images/android-chrome-512x512.png" class="rounded-circle" width="45" alt="Logo" /></div>
            <div class="p-2">
                <div class="app-name">GIS-Gboko</div>
                <div class="app-sub">School Management</div>
            </div>
        </div>

        <div class="nav-section-label">Overview</div>
        <a asp-page="/index" class="nav-link"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
        @* <a href="#" class="nav-link"><i class="bi bi-calendar3"></i> Schedule</a>
        <a href="#" class="nav-link"><i class="bi bi-bell-fill"></i> Announcements <span class="badge-pill">3</span></a> *@

        <div class="nav-section-label">Academic</div>
        <a asp-page="/admin/admission/index" class="nav-link"><i class="bi bi-people-fill"></i> Admission</a>
        <div class="nav-dropdown">
            <a href="#" class="nav-link " data-bs-toggle="collapse" data-bs-target="#termRegMenu" aria-expanded="false">
                <i class="bi bi-people"></i> Term Registration
                <i class="bi bi-chevron-down ms-auto"></i>
            </a>
            <div class="collapse" id="termRegMenu">
                <ul class="dropdown-menu-list">
                    <li><a asp-page="/admin/termly-registeration/index" class="dropdown-item"><i class="bi bi-list-check"></i> List</a></li>
                    <li><a asp-page="/admin/termly-registeration/upsert" class="dropdown-item"><i class="bi bi-person-badge-fill"></i> Single Reg.</a></li>
                    <li><a asp-page="/admin/termly-registeration/batch-registration" class="dropdown-item"><i class="bi bi-people-fill"></i> Batch Reg.</a></li>
                </ul>
            </div>
        </div>
        <a asp-page="/admin/schoolclass/index" class="nav-link"><i class="bi bi-building-fill"></i> School Classes</a>
        <a asp-page="/admin/sub-class/index" class="nav-link"><i class="bi bi-layers-fill"></i> School Sub-Classes</a>
        <a asp-page="/admin/academicsession/index" class="nav-link"><i class="bi bi-calendar3-event-fill"></i> Academic Sessions</a>
        @* <a href="#" class="nav-link"><i class="bi bi-book-fill"></i> Subjects</a>
        <a href="#" class="nav-link"><i class="bi bi-clipboard2-data-fill"></i> Exams & Results</a>
        <a href="#" class="nav-link"><i class="bi bi-journal-check"></i> Attendance <span class="badge-pill">7</span></a> *@

        <div class="nav-section-label">Finance</div>
        @if (canReport)
        {
        <div class="nav-dropdown">
            <a href="#" class="nav-link " data-bs-toggle="collapse" data-bs-target="#financeMenu" aria-expanded="false">
                <i class="bi bi-cash-coin"></i> Payment Setup
                <i class="bi bi-chevron-down ms-auto"></i>
            </a>
            <div class="collapse" id="financeMenu">
                <ul class="dropdown-menu-list">
                    <li><a asp-page="/admin/payment-categories/index" class="dropdown-item"><i class="bi bi-tag-fill"></i> Categories</a></li>
                    <li><a asp-page="/admin/payment-items/index" class="dropdown-item"><i class="bi bi-receipt"></i> Payment Items</a></li>
                    <li><a asp-page="/admin/payment-setup/index" class="dropdown-item"><i class="bi bi-gear-wide-connected"></i> Setup Config</a></li>
                </ul>
            </div>
        </div>
        }
        <div class="nav-dropdown">
            <a href="#" class="nav-link " data-bs-toggle="collapse" data-bs-target="#studentPaymentsMenu" aria-expanded="false">
                <i class="bi bi-cash-stack"></i> Student Payments
                <i class="bi bi-chevron-down ms-auto"></i>
            </a>
            <div class="collapse" id="studentPaymentsMenu">
                <ul class="dropdown-menu-list">
                    <li><a asp-page="/admin/student-payments/index" class="dropdown-item"><i class="bi bi-list-check"></i> Payment History</a></li>
                    <li><a asp-page="/admin/student-payments/make-payment" class="dropdown-item"><i class="bi bi-credit-card"></i> Make Payment</a></li>
                </ul>
            </div>
        </div>
        @if (canReport)
        {
        <div class="nav-dropdown">
            <a href="#" class="nav-link " data-bs-toggle="collapse" data-bs-target="#reportsMenu" aria-expanded="false">
                <i class="bi bi-graph-up-arrow"></i> Payment Reports
                <i class="bi bi-chevron-down ms-auto"></i>
            </a>
            <div class="collapse" id="reportsMenu">
                <ul class="dropdown-menu-list">
                    <li><a asp-page="/admin/payment-reports/class-report" class="dropdown-item"><i class="bi bi-clipboard-data"></i> Class Report</a></li>
                    <li><a asp-page="/admin/payment-reports/school-report" class="dropdown-item"><i class="bi bi-bar-chart-line"></i> School Report</a></li>
                    <li><a asp-page="/admin/payment-reports/category-report" class="dropdown-item"><i class="bi bi-tags"></i> Category Report</a></li>
                </ul>
            </div>
        </div>
        }

        <div class="nav-section-label">Administration</div>

        @if (userInfo.CanManageHR)
        {
            <!-- HR & Staff Dropdown Menu -->
            <div class="nav-dropdown">
                <a href="#" class="nav-link " data-bs-toggle="collapse" data-bs-target="#hrMenu" aria-expanded="false">
                    <i class="bi bi-person-badge"></i> HR & Staff
                    <i class="bi bi-chevron-down ms-auto"></i>
                </a>
                <div class="collapse" id="hrMenu">
                    <ul class="dropdown-menu-list">
                        <li><a asp-page="/admin/employees/index" class="dropdown-item"><i class="bi bi-people"></i> Employees</a></li>
                        <li><a asp-page="/admin/positions/index" class="dropdown-item"><i class="bi bi-briefcase-fill"></i> Positions</a></li>
                    </ul>
                </div>
            </div>
        }

        @if (userInfo.CanManageSecurity)
        {
            <!-- Security & Roles Dropdown Menu -->
            <div class="nav-dropdown">
                <a href="#" class="nav-link " data-bs-toggle="collapse" data-bs-target="#securityMenu" aria-expanded="false">
                    <i class="bi bi-shield-lock-fill"></i> Security & Roles
                    <i class="bi bi-chevron-down ms-auto"></i>
                </a>
                <div class="collapse" id="securityMenu">
                    <ul class="dropdown-menu-list">
                        <li><a asp-page="/admin/roles/index" class="dropdown-item"><i class="bi bi-shield-check"></i> Roles & Permissions</a></li>
                    </ul>
                </div>
            </div>
        }

        @* <a href="#" class="nav-link"><i class="bi bi-building-fill"></i> Classes & Rooms</a>
        <a href="#" class="nav-link"><i class="bi bi-bus-front-fill"></i> Transport</a> *@
        @if (userInfo.IsAdmin)
        {
            <div class="nav-section-label">System</div>
            <a asp-page="/admin/app-settings" class="nav-link"><i class="bi bi-gear-fill"></i> Settings</a>
            <a href="#" class="nav-link"><i class="bi bi-question-circle-fill"></i> Help & Support</a>
        }

        <div class="sidebar-footer d-flex align-items-center gap-2">
            <div class="avatar">@userInitials</div>
            <div>
                <div class="user-name">@userDisplayName</div>
                <div class="user-role">@userPosition</div>
            </div>
            <a asp-page="/account/change-password" title="Change Password" style="margin-left:auto;">
                <i class="bi bi-key-fill" style="color:rgba(255,255,255,.4);cursor:pointer;font-size:1rem;"></i>
            </a>
            <a asp-page="/account/logout" title="Sign Out">
                <i class="bi bi-box-arrow-right" style="color:rgba(255,255,255,.4);cursor:pointer;font-size:1rem;"></i>
            </a>
        </div>
    </nav>

    <!-- OVERLAY -->
    <div id="overlay"></div>

    <!-- TOPBAR -->
    <header id="topbar">
        <button class="menu-btn" id="menuBtn"><i class="bi bi-list"></i></button>
        <div class="page-title">Dashboard</div>
        <div class="search-wrap">
            <i class="bi bi-search search-icon"></i>
            <input type="text" placeholder="Search students, classes…" />
        </div>

        <!-- Dark Mode Toggle -->
        <div class="icon-btn" id="darkToggle" title="Toggle dark mode">
            <i class="bi bi-moon"></i>
        </div>

        <!-- NOTIFICATION BELL -->
        @if (canReport)
        {
        <div class="notif-wrap" id="notifWrap">
            <div class="icon-btn" id="notifBtn" title="Pending Payments">
                <i class="bi bi-bell-fill"></i>
                <span class="notif-dot" id="notifDot" style="display:none;"></span>
            </div>
            <!-- Notification Panel -->
            <div class="notif-panel" id="notifPanel">
                <div class="drop-header">
                    <div class="d-flex align-items-center gap-1">
                        <span class="drop-title">Pending Payments</span>
                        <span class="unread-count" id="notifCount" style="display:none;">0</span>
                    </div>
                </div>
                <div id="notifList">
                    <div class="text-center text-muted py-3" style="font-size:.85rem;">Loading...</div>
                </div>
                <div class="notif-footer"><a href="/admin/student-payments">View all payments →</a></div>
            </div>
        </div>
        }

        <!-- MESSAGES -->
        <div class="notif-wrap" id="msgWrap">
            <div class="icon-btn" id="msgBtn" title="Messages">
                <i class="bi bi-envelope-fill"></i>
                <span class="notif-dot" style="background:#a855f7;"></span>
            </div>
            <!-- Messages Panel -->
            <div class="notif-panel" id="msgPanel" style="width:340px;">
                <div class="drop-header">
                    <div class="d-flex align-items-center gap-1">
                        <span class="drop-title">Messages</span>
                        <span class="unread-count" style="background:#a855f7;">3</span>
                    </div>
                    <span class="drop-mark">Mark all read</span>
                </div>

                <!-- Message Items -->
                <div class="msg-item unread">
                    <div class="msg-ava" style="background:#e8f4ff;color:#3b82f6;">MR</div>
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center">
                            <span class="msg-sender">Mr. Rasheed (HOD Math)</span>
                            <span class="msg-time">9:42 AM</span>
                        </div>
                        <div class="msg-preview">Please approve the new exam schedule I submitted yesterday.</div>
                    </div>
                    <div class="msg-unread-dot"></div>
                </div>
                <div class="msg-item unread">
                    <div class="msg-ava" style="background:#fef4d3;color:#c4860e;">FO</div>
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center">
                            <span class="msg-sender">Finance Officer</span>
                            <span class="msg-time">8:15 AM</span>
                        </div>
                        <div class="msg-preview">Monthly fee report is ready for your review and signature.</div>
                    </div>
                    <div class="msg-unread-dot"></div>
                </div>
                <div class="msg-item unread">
                    <div class="msg-ava" style="background:#fff0f2;color:var(--rose);">PT</div>
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center">
                            <span class="msg-sender">Parent: Tunde's Dad</span>
                            <span class="msg-time">Yesterday</span>
                        </div>
                        <div class="msg-preview">I would like to discuss my son's attendance record this term.</div>
                    </div>
                    <div class="msg-unread-dot"></div>
                </div>
                <div class="msg-item">
                    <div class="msg-ava" style="background:#e6faf4;color:var(--mint);">VP</div>
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center">
                            <span class="msg-sender">Vice Principal</span>
                            <span class="msg-time">Mar 25</span>
                        </div>
                        <div class="msg-preview">Staff meeting rescheduled to Friday 8:00 AM. Please notify all HODs.</div>
                    </div>
                </div>
                <div class="msg-item">
                    <div class="msg-ava" style="background:#f0e8ff;color:#a855f7;">IT</div>
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center">
                            <span class="msg-sender">IT Support</span>
                            <span class="msg-time">Mar 24</span>
                        </div>
                        <div class="msg-preview">Portal maintenance completed. All modules are now online.</div>
                    </div>
                </div>

                <div class="notif-footer"><a href="#">Open full inbox →</a></div>
            </div>
        </div>

        <!-- PROFILE AVATAR + DROPDOWN -->
        <div class="profile-wrap" id="profileWrap">
            <div class="top-avatar" id="profileBtn" title="My Account">@userInitials</div>
            <!-- Profile Dropdown -->
            <div class="profile-dropdown" id="profileDropdown">
                <div class="pd-header">
                    <div class="pd-avatar">@userInitials</div>
                    <div>
                        <div class="pd-name">@userDisplayName</div>
                        <div class="pd-email">@User.Identity?.Name</div>
                        <div class="pd-role-badge">@userRoleBadge</div>
                    </div>
                </div>
                <div class="pd-menu">
                    @* <a href="#" class="pd-item"><i class="bi bi-person-circle"></i> My Profile</a>
                    <a href="#" class="pd-item"><i class="bi bi-shield-lock-fill"></i> Account Security</a>
                    <a href="#" class="pd-item"><i class="bi bi-bell-fill"></i> Notification Preferences</a> *@
                    <hr class="pd-divider" />
                    <a asp-page="/admin/app-settings" class="pd-item"><i class="bi bi-building-fill"></i> Settings</a>
                    @* <a href="#" class="pd-item"><i class="bi bi-people-fill"></i> Manage Roles & Users</a>
                    <a href="#" class="pd-item"><i class="bi bi-file-earmark-bar-graph-fill"></i> Activity Log</a> *@
                    <hr class="pd-divider" />
                    <a asp-page="/account/change-password" class="pd-item"><i class="bi bi-key-fill"></i> Change Password</a>
                    <a href="#" class="pd-item"><i class="bi bi-patch-check-fill"></i> v2.4.1 — Check for Updates</a>
                    <hr class="pd-divider" />
                    <a asp-page="/account/logout" class="pd-item danger"><i class="bi bi-box-arrow-right"></i> Sign Out</a>
                </div>
            </div>
        </div>

    </header>
    <main id="main">
        @RenderBody()
        <footer id="site-footer">
            <div class="d-flex flex-column flex-sm-row align-items-center justify-content-center gap-2 gap-sm-4">
                <span>© 2026 <span>Graham International School</span>. All rights reserved.</span>
                <span class="d-none d-sm-inline" style="opacity:.3;">|</span>
                <span>Designed &amp; Developed by <span>D-Best Return Tech</span></span>
                <span class="d-none d-sm-inline" style="opacity:.3;">|</span>
                <span>
                    <a href="#">Privacy Policy</a> &nbsp;·&nbsp;
                    <a href="#">Terms of Use</a> &nbsp;·&nbsp;
                    <a href="#">Support</a>
                </span>
            </div>
        </footer>

    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/twitter-bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>