@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.schoolclass.indexModel
@{
    ViewData["Title"] = "School Classes";
}

@section Sheets{
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <partial name="_DatatablesSheetFiles" />
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-building-fill"></i> School Classes Management
        </h1>
        <p class="text-muted">Manage and organize school classes</p>
    </div>
    <div class="header-actions">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#schoolClassModal" onclick="resetForm()">
            <i class="bi bi-plus-circle me-2"></i>Add School Class
        </button>
    </div>
</div>

<div class="page-content">
    <!-- Success Alert -->
    @if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Alert -->
    @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Error!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search and Filter -->
    <div class="search-filter-area">
        <div class="search-group">
            <label for="searchInput">Search Classes:</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Search by class name...">
        </div>
    </div>

    <!-- DataTable Container -->
    <div class="datatable-container">
        <table id="schoolClassesTable" class="table table-hover">
            <thead>
                <tr>
                    <th class="col-1">#</th>
                    <th class="col-4">Class Name</th>
                    <th class="col-3">Created Date</th>
                    <th class="col-3">Last Updated</th>
                    <th class="col-1">Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="schoolClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-building-fill me-2"></i>Add School Class
                    </h5>
                    <small>Create new school class information</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post">
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="SchoolClassModel.Name">
                            <i class="bi bi-pencil-square me-1"></i>Class Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" asp-for="SchoolClassModel.Name"
                               placeholder="Enter class name (e.g., JSS 1, SSS 2)" required maxlength="50">
                        <small class="form-text text-muted">Maximum 50 characters</small>
                        <span class="invalid-feedback" asp-validation-for="SchoolClassModel.Name"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="schoolClassEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-building-fill me-2"></i>Edit School Class
                    </h5>
                    <small>Update school class information</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post">
                <div class="modal-body">
                    <input type="hidden" asp-for="SchoolClassModel.Id" id="editClassId" />

                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="SchoolClassModel.Name">
                            <i class="bi bi-pencil-square me-1"></i>Class Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" asp-for="SchoolClassModel.Name" id="editClassName"
                               placeholder="Enter class name (e.g., JSS 1, SSS 2)" required maxlength="50">
                        <small class="form-text text-muted">Maximum 50 characters</small>
                        <span class="invalid-feedback" asp-validation-for="SchoolClassModel.Name"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Update
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_DatatablesScriptsFiles" />
    <script src="~/js/appmain.js"></script>
}
