@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.other_payments.fees_payment.add_paymentModel
@{
    ViewData["Title"] = "Record Other Fees Payments";
}
@section Sheets {
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <partial name="_DatatablesSheetFiles" />
}
<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-cash-coin"></i> Record Other Fees Payments
        </h1>
        <p class="text-white-50">Record Student Other Fees payments</p>
    </div>
    <div class="header-actions">
        <div class="btn-group">
            <a asp-page="index" class="btn btn-primary"><i class="bi bi-arrow-left me-2"></i> Back</a>
        </div>
    </div>
</div>
<div class="page-content">
    <!-- Success Alert -->
    @if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Alert -->
    @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Error!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Search Section -->
    <form method="post" asp-page-handler="Search" class="mb-4">
        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0 text-white"><i class="bi bi-search"></i> Search Student</h5>
            </div>
            <div class="card-body">
                <div class="row g-1 mb-3">
                    <div class="col-md-2">
                        <label for="term" class="form-label">Term</label>
                        <select class="form-select" asp-for="RecordSearch.term" asp-items="@Model.Selections.Terms">
                            <option value="">---Select Term---</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Academic Session</label>
                        <select class="form-select" asp-for="RecordSearch.sessionid" asp-items="@Model.Selections.AcademicSession">
                            <option value="">---Select Session---</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Class</label>
                        <select class="form-select" asp-for="RecordSearch.schoolclass" asp-items="@Model.Selections.SchoolClasses">
                            <option value="">---Select Class---</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Payment Item</label>
                        <select class="form-select" asp-for="RecordSearch.otherpayitemid" asp-items="@Model.Selections.PaymentItems">
                            <option value="">---Select Payment Item---</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="studentRegNumber" class="form-label">Student Reg. No.</label>
                        <input type="search" class="form-control" asp-for="RecordSearch.StudentRegNumber" placeholder="Enter registration number"/>
                    </div>
                    <div class="col-md-1">
                        <button class="btn btn-success mt-4" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <!-- Payment Recording Section -->
    @if (Model.Record?.termregid > 0)
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Complete Payment - @(Model.Record.name + " - " + Model.Record.schoolclass)</h5>
            </div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data" asp-page-handler="MakePayment">
                    <!-- Student Information -->
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label"><strong>Full Name</strong></label>
                            <input type="text" asp-for="Record.name" class="form-control" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><strong>Student Registration Number</strong></label>
                            <input type="text" asp-for="Record.regnumber" class="form-control" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><strong>Payment Item</strong></label>
                            <input type="text" class="form-control" readonly asp-for="Record.otherPayment">
                        </div>
                    </div>

                    <!-- Academic Information -->
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label"><strong>Term</strong></label>
                            <input asp-for="Record.term" class="form-control" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><strong>Academic Session</strong></label>
                            <input asp-for="Record.session" class="form-control" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><strong>Class</strong></label>
                            <input asp-for="Record.schoolclass" class="form-control" readonly>
                        </div>
                    </div>

                    <!-- Fee Information -->
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label"><strong>Other Fees Amount</strong></label>
                            <input asp-for="Record.feespayment" class="form-control" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><strong>Total Payment</strong></label>
                            <input asp-for="Record.totalamount" class="form-control" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label"><strong>Balance</strong></label>
                            <input asp-for="Record.balance" class="form-control" readonly>
                            <input id="balance" values="@Model.Record.balance" type="hidden">
                        </div>
                    </div>

                    <hr />

                    <!-- Payment Details -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label"><strong>Payment Amount <span class="text-danger">*</span></strong></label>
                            <input asp-for="Record.amount" class="form-control" placeholder="Enter payment amount" required>
                            <span class="form-text text-muted">Amount must not exceed balance</span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><strong>Payment Evidence/Receipt <span class="text-danger">*</span></strong></label>
                            <input type="file" asp-for="Record.evidenncefile" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.gif" required>
                            <span class="form-text text-muted">Upload bank teller, receipt or payment proof (PDF, JPG, PNG)</span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label"><strong>Notes (Optional)</strong></label>
                            <textarea asp-for="Record.narration" class="form-control" rows="3" placeholder="Add any notes about this payment..."></textarea>
                        </div>
                    </div>

                    <!-- Hidden Fields -->
                    <input type="hidden" asp-for="Record.termregid" />
                    <input type="hidden" asp-for="Record.FeesSetUpid" />
                    <input type="hidden" asp-for="Record.balance" />

                    <!-- Action Buttons -->
                    <div class="row mt-4">
                        <div class="col-md-12">
                            <button class="btn btn-primary btn-lg" type="submit">
                                <i class="bi bi-check-circle me-2"></i> Record Payment
                            </button>
                            <a asp-page="index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle me-2"></i> Cancel
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle me-2"></i>
            <strong>Instruction:</strong> Use the search form above to find and select a student before recording a payment.
        </div>
    }
</div>

@section Scripts{
    <script src="~/lib/sweetalert2/sweetalert2.all.js"></script>
    <script>
        $(document).ready(function () {

            $('#Record_amount').on('input', function () {

                let amount = parseFloat($(this).val()) || 0;
                let fees = parseFloat($('#Record_feespayment').val()) || 0;
                let bal = parseFloat($('#Record_totalamount').val()) || 0;

                let balance = fees - (amount+bal);

                // Prevent negative balance (optional)
                if (balance < 0) {
                    balance = 0;
                    $('#Record_balance').val(balance.toFixed(2));
                    $('#Record_amount').val(0);
                    return Swal.fire({
                          icon: "error",
                          title: "Calculation Error",
                          text: "Amount paying can not exceed fees amount!",
                        });
                }

                $('#Record_balance').val(balance.toFixed(2));
            });

        });
    </script>
}
