@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.other_payments.fees_payment.indexModel
@{
    ViewData["Title"] = "Other Fees Payments History";
}
@section Sheets {
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <partial name="_DatatablesSheetFiles" />
}
<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-list-check"></i> Other Fees Payment History
        </h1>
        <p class="text-white-50">Manage Other Fees payments</p>
    </div>
    <div class="header-actions">
        <div class="btn-group">
            <a asp-page="/admin/other-payments/other-payments-report" class="btn btn-info"><i class="bi bi-receipt me-2"></i> View Report</a>
            <a asp-page="add-payment" class="btn btn-primary"><i class="bi bi-plus-circle me-2"></i> Record Payment</a>
        </div>
    </div>
</div>
<div class="page-content">
    <!-- Success Alert -->
    @if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Alert -->
    @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Error!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Filters -->
    <div class="row mb-4">
        <div class="col-md-3">
            <label for="term" class="form-label">Term</label>
            <select class="form-select" id="term" asp-items="@Model.Selections.Terms">
                <option value="">---Select Term---</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="session" class="form-label">Academic Session</label>
            <select class="form-select" id="session" asp-items="@Model.Selections.AcademicSession">
                <option value="">---Select Session---</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="schoolclass" class="form-label">Class</label>
            <select class="form-select" id="schoolclass" asp-items="@Model.Selections.SchoolClasses">
                <option value="">---Select Class---</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="paymentitem" class="form-label">Payment Item</label>
            <select class="form-select" id="paymentitem" asp-items="@Model.Selections.PaymentItems">
                <option value="">---Select Payment Item---</option>
            </select>
        </div>
    </div>

    <!-- DataTable Container -->
    <div class="datatable-container">
        <table id="otherFeesPaymentTable" class="table table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Reg. Number</th>
                    <th>Academic Session</th>
                    <th>Payment Item</th>
                    <th>State</th>
                    <th>Status</th>
                    <th>Amount Paid</th>
                    <th>Created Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_DatatablesScriptsFiles" />
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/lib/jquery.blockui/jquery.blockui.min.js"></script>
    <script>
        var table;

        $(document).ready(function () {
            initializeDataTable();

            // Bind filter events
            $('#term, #session, #schoolclass, #paymentitem').on('change', function () {
                table.draw();
            });
        });

        function initializeDataTable() {
            table = $('#otherFeesPaymentTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/home/GetOtherFeesPayments',
                    type: 'POST',
                    data: function (d) {
                        d.term = $('#term').val();
                        d.session = $('#session').val();
                        d.schoolClass = $('#schoolclass').val();
                        d.paymentItem = $('#paymentitem').val();
                    }
                },
                columns: [
                    { data: null, orderable: false, searchable: false, autoWidth: true,
                            render: function (data, type, row, meta) {
                                return meta.settings._iDisplayStart + meta.row + 1;
                            }
                    },
                    { data: 'name' },
                    { data: 'regnumber' },
                    {
                        data: null, autoWidth: true,
                        render: function (data, type, row) {
                            return `
                                <div class=''>
                                    <span class="bg-primary badge">${row.session}</span>
                                    <small>${row.term} - ${row.schoolclass}</small>
                                </div>
                            `;
                        }
                    },
                    { data: 'paymentitem', autoWidth: true},
                    { data: 'state', autoWidth: true},
                    { data: 'status', autoWidth: true},
                    { data: 'amount',autoWidth: true},
                    {
                        data: "createdate",
                        autoWidth: true,
                        render: function (data, type, row) {
                            if (data != null) {
                                let date = new Date(data);
                                return date.toLocaleString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
                            }
                            return "N/A";
                        }
                        },
                    {
                        data: null,
                        render: function (data, type, row) {
                            return `
                            <div class="dropdown">
                                        <button class="btn btn-dark btn-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-three-dots-vertical me-1"></i>
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li><a class="dropdown-item" href="/admin/other-payments/fees-payment/view-payment-detail?id=${row.id}"><i class="bi bi-eye"></i> View Details</a></li>
                                            <li><a class="dropdown-item" href="/admin/other-payments/fees-payment/payment-receipt?paymentId=${row.id}" target="_blank"><i class="bi bi-printer"></i> Print Receipt</a></li>
                                            <li><button class="dropdown-item btn-delete-otherPayment" data-id="${row.id}"><i class="bi bi-trash"></i> Delete</button></li>
                                        </ul>
                                    </div>`;
                        }
                    }
                ],
                columnDefs: [
                    { targets: 0, width: '5%' },
                    { targets: -1, width: '12%', orderable: false }
                ],
                order: [[8, 'desc']],
                pageLength: 10,
                responsive: true
            });
        }
    </script>
}
