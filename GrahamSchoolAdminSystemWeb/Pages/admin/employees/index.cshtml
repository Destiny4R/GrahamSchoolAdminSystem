@page
@inject IUnitOfWork _unitOfWork
@model GrahamSchoolAdminSystemWeb.Pages.admin.employees.IndexModel
@using GrahamSchoolAdminSystemAccess
@{
    ViewData["Title"] = "Employee Management - Graham School Admin System";
    await Permissions.InitializeAsync(User);
}
@section Sheets {
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <partial name="_DatatablesSheetFiles" />
    <style>
        .avatar-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1a2b6d 0%, #0b1437 100%);
            color: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
            border: 2px solid var(--gold);
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            margin: 2rem 0;
            background: #f8f9fa;
            border-radius: 14px;
            border: 2px dashed #dee2e6;
        }

        .empty-state-icon {
            font-size: 4rem;
            color: var(--navy);
            opacity: 0.3;
            margin-bottom: 1.5rem;
        }

        .empty-state h5 {
            color: var(--navy);
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            color: #6c757d;
            margin-bottom: 1.5rem;
        }
    </style>
}



<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-people-fill"></i> Employee Management
        </h1>
        <p class="text-white">Manage employees, assign positions, and track roles</p>
    </div>
    <div class="header-actions">
        @if (Permissions.CanCreate)
        {
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addEmployeeModal">
            <i class="bi bi-plus-circle me-2"></i>Add Employee
        </button>
        }
    </div>
</div>

<div class="page-content">
    <!-- Success Alert -->
    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Alert -->
    @if (!string.IsNullOrEmpty(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Error!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Employees DataTable -->
    <div class="datatable-container">
        <table id="employeesTable" class="table table-hover">
            <thead>
                <tr>
                    <th class="col-1">#</th>
                    <th class="col-2">Name</th>
                    <th class="col-2">Email</th>
                    <th class="col-2">Phone</th>
                    <th class="col-2">Position</th>
                    <th class="col-1">Roles</th>
                    <th class="col-1">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Add Employee Modal -->
@if (Permissions.CanCreate)
{
<div class="modal fade" id="addEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-person-plus-fill me-2"></i>Add Employee
                    </h5>
                    <small>Create new employee account</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="AddEmployee">
                <div class="modal-body">
                    <div class="row">
                        <div class="form-group mb-3 col-md-6">
                            <label class="form-label">
                                <i class="bi bi-person me-1"></i>First Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" asp-for="EmployeeModel.FirstName"  placeholder="Enter first name" required>
                        </div>
                        <div class="form-group mb-3 col-md-6">
                            <label class="form-label">
                                <i class="bi bi-person me-1"></i>Last Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" asp-for="EmployeeModel.LastName"  placeholder="Enter last name" required>
                        </div>
                    </div>
                    @* <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-person me-1"></i>First Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" asp-for="EmployeeModel.FirstName" placeholder="Enter first name" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-person me-1"></i>Last Name <span class="text-danger">*</span>
                        </label>
                            <input type="text" class="form-control" asp-for="EmployeeModel.LastName" placeholder="Enter last name" required>
                    </div> *@
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-envelope me-1"></i>Email <span class="text-danger">*</span>
                        </label>
                        <input type="email" class="form-control" name="EmployeeModel.Email" placeholder="Enter email address" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-telephone me-1"></i>Phone <span class="text-danger">*</span>
                        </label>
                        <input type="tel" class="form-control" asp-for="EmployeeModel.Phone" placeholder="Enter phone number" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-building me-1"></i>Address
                        </label>
                        <input type="text" class="form-control" asp-for="EmployeeModel.Address" placeholder="">
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-briefcase me-1"></i>Position
                        </label>
                            <select class="form-select" asp-for="EmployeeModel.PositionId" asp-items="_unitOfWork.UsersServices.PositionsList()">
                            <option selected disabled value="">-- No position --</option>
                        </select>
                        <small class="text-muted">Position determines the employee's roles and permissions</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Create Employee
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
}

<!-- Edit Employee Modal -->
@if (Permissions.CanEdit)
{
<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-pencil-square me-2"></i>Edit Employee
                    </h5>
                    <small>Update employee information</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="UpdateEmployee">
                <div class="modal-body">
                    <input type="hidden" asp-for="EmployeeModel.Id" id="editEmployeeId">
                    <div class="row">
                        <div class="form-group mb-3 col-md-6">
                            <label class="form-label">
                                <i class="bi bi-person me-1"></i>First Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" asp-for="EmployeeModel.FirstName" id="editFirstName" placeholder="Enter first name" required>
                        </div>
                        <div class="form-group mb-3 col-md-6">
                            <label class="form-label">
                                <i class="bi bi-person me-1"></i>Last Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" asp-for="EmployeeModel.LastName" id="editLastName" placeholder="Enter last name" required>
                        </div>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-envelope me-1"></i>Email <span class="text-danger">*</span>
                        </label>
                        <input type="email" class="form-control" asp-for="EmployeeModel.Email" id="editEmail" placeholder="Enter email address" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-telephone me-1"></i>Phone <span class="text-danger">*</span>
                        </label>
                        <input type="tel" class="form-control" asp-for="EmployeeModel.Phone" id="editPhone" placeholder="Enter phone number" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-telephone me-1"></i>Address <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" asp-for="EmployeeModel.Address" id="editAddress" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-briefcase me-1"></i>Position
                        </label>
                        <select class="form-select" asp-for="EmployeeModel.PositionId" id="editPositionId" asp-items="_unitOfWork.UsersServices.PositionsList()">
                            <option selected disabled value="">-- No position --</option>
                        </select>
                        <small class="text-muted">Position determines the employee's roles and permissions</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Update Employee
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
}

<!-- Assign Position Modal -->
@if (Permissions.CanEdit)
{
<div class="modal fade" id="assignPositionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-person-badge-fill me-2"></i>Assign Position
                    </h5>
                    <small id="assignEmployeeName">Assign position to employee</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="AssignPosition">
                <div class="modal-body">
                    <input type="hidden" name="EmployeePositionModel.EmployeeId" id="assignEmployeeId">
                    
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <strong>Note:</strong> Selecting a position will automatically link it to this employee. Positions determine access rights and responsibilities.
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-briefcase me-1"></i>Select Position <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" name="EmployeePositionModel.PositionId" asp-items="_unitOfWork.UsersServices.PositionsList()" required>
                            <option selected disabled value="">-- Select a position --</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Assign Position
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_DatatablesScriptsFiles" />
    <script>
        window.userPermissions = {
            canCreate: @Json.Serialize(Permissions.CanCreate),
            canEdit: @Json.Serialize(Permissions.CanEdit),
            canDelete: @Json.Serialize(Permissions.CanDelete)
        };
    </script>
    <script src="~/js/appmain.js"></script>
    
    <script>
        $(document).ready(function() {
            // Role badge class mapping
            function getRoleBadgeClass(roleName) {
                switch (roleName) {
                    case 'Admin': return 'badge bg-danger';
                    case 'Accountant': return 'badge bg-warning text-dark';
                    case 'Cashier': return 'badge bg-success';
                    default: return 'badge bg-secondary';
                }
            }

            // Escape HTML to prevent XSS
            function escapeHtml(text) {
                if (!text) return '';
                var div = document.createElement('div');
                div.appendChild(document.createTextNode(text));
                return div.innerHTML;
            }

            // Initialize DataTable with server-side processing
            var employeesTable = $('#employeesTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/home/GetEmployeesDataTable',
                    type: 'POST'
                },
                order: [[1, 'asc']],
                columns: [
                    {
                        data: null,
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    {
                        data: 'firstName',
                        render: function (data, type, row) {
                            var initials = (row.firstName ? row.firstName.charAt(0) : '') + (row.lastName ? row.lastName.charAt(0) : '');
                            return '<div class="d-flex align-items-center">' +
                                '<div class="avatar-circle me-2">' + escapeHtml(initials) + '</div>' +
                                '<div><strong>' + escapeHtml(row.firstName) + ' ' + escapeHtml(row.lastName) + '</strong></div>' +
                                '</div>';
                        }
                    },
                    {
                        data: 'email',
                        render: function (data) {
                            return escapeHtml(data);
                        }
                    },
                    {
                        data: 'phone',
                        render: function (data) {
                            return data ? escapeHtml(data) : '-';
                        }
                    },
                    {
                        data: 'positionName',
                        orderable: false,
                        render: function (data) {
                            if (data) {
                                return '<span class="badge bg-info-subtle text-info"><i class="bi bi-briefcase-fill me-1"></i>' + escapeHtml(data) + '</span>';
                            }
                            return '<span class="text-muted">No position assigned</span>';
                        }
                    },
                    {
                        data: 'roles',
                        orderable: false,
                        searchable: false,
                        render: function (data) {
                            if (data && data.length > 0) {
                                return data.map(function (role) {
                                    return '<span class="' + getRoleBadgeClass(role) + ' me-1">' + escapeHtml(role) + '</span>';
                                }).join('');
                            }
                            return '<span class="text-muted fst-italic">—</span>';
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row) {
                            var perms = window.userPermissions || {};
                            var fullName = escapeHtml(row.firstName + ' ' + row.lastName);
                            var items = '';
                            if (perms.canEdit) {
                                items += '<li><button type="button" class="dropdown-item btn-edit-employee"' +
                                    ' data-id="' + row.id + '"' +
                                    ' data-firstname="' + escapeHtml(row.firstName) + '"' +
                                    ' data-lastname="' + escapeHtml(row.lastName) + '"' +
                                    ' data-email="' + escapeHtml(row.email) + '"' +
                                    ' data-address="' + escapeHtml(row.address) + '"' +
                                    ' data-phone="' + escapeHtml(row.phone) + '"' +
                                    ' data-positionid="' + (row.positionId || '') + '"' +
                                    ' title="Edit">' +
                                    '<i class="bi bi-pencil-fill me-2"></i> Edit</button></li>';
                                items += '<li><button type="button" class="dropdown-item btn-assign-position"' +
                                    ' data-id="' + row.id + '"' +
                                    ' data-name="' + fullName + '"' +
                                    ' title="Assign Position">' +
                                    '<i class="bi bi-person-badge-fill me-2"></i> Assign Position</button></li>';
                            }
                            if (perms.canDelete) {
                                if (items) items += '<li><hr class="dropdown-divider"></li>';
                                items += '<li><button type="button" class="dropdown-item btn-delete-employee"' +
                                    ' data-id="' + row.id + '"' +
                                    ' data-name="' + fullName + '"' +
                                    ' title="Delete">' +
                                    '<i class="bi bi-trash-fill me-2"></i> Delete</button></li>';
                            }
                            if (!items) return '';
                            return '<div>' +
                                '<button type="button" class="btn btn-primary btn-sm" data-bs-toggle="dropdown" aria-expanded="false">' +
                                '<i class="bi bi-three-dots-vertical"></i></button>' +
                                '<ul class="dropdown-menu">' + items + '</ul></div>';
                        }
                    }
                ],
                language: {
                    emptyTable: 'No employees found',
                    zeroRecords: 'No matching employees found'
                }
            });

            // Handle Edit button click
            $(document).on('click', '.btn-edit-employee', function() {
                var btn = $(this);
                $('#editEmployeeId').val(btn.data('id'));
                $('#editFirstName').val(btn.data('firstname'));
                $('#editLastName').val(btn.data('lastname'));
                $('#editEmail').val(btn.data('email'));
                $('#editPhone').val(btn.data('phone'));
                $('#editAddress').val(btn.data('address'));
                $('#editPositionId').val(btn.data('positionid'));

                var editModal = new bootstrap.Modal(document.getElementById('editEmployeeModal'));
                editModal.show();
            });

            // Handle Assign Position button click
            $(document).on('click', '.btn-assign-position', function() {
                var id = $(this).data('id');
                var name = $(this).data('name');

                $('#assignEmployeeId').val(id);
                $('#assignEmployeeName').text('Assign position to ' + name);

                var assignModal = new bootstrap.Modal(document.getElementById('assignPositionModal'));
                assignModal.show();
            });

            // Handle Delete button click
            $(document).on('click', '.btn-delete-employee', function() {
                var id = $(this).data('id');
                var name = $(this).data('name');

                Swal.fire({
                    title: 'Delete Employee?',
                    html: 'Are you sure you want to delete <strong>' + name + '</strong>?<br><small class="text-muted">This action cannot be undone.</small>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="bi bi-trash me-1"></i>Yes, delete',
                    cancelButtonText: '<i class="bi bi-x-circle me-1"></i>Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        var form = $('<form method="post" action="?handler=DeleteEmployee"></form>');
                        form.append('<input type="hidden" name="id" value="' + id + '">');
                        form.append('<input type="hidden" name="__RequestVerificationToken" value="' + $('input[name="__RequestVerificationToken"]').val() + '">');
                        $('body').append(form);
                        form.submit();
                    }
                });
            });
        });
    </script>
}
