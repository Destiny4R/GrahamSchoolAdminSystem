@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.employees.IndexModel
@using GrahamSchoolAdminSystemAccess
@{
    ViewData["Title"] = "Employee Management - Graham School Admin System";
}

<link rel="stylesheet" href="~/css/shared-components.css" />
<link rel="stylesheet" href="~/css/admin-pages.css" />
<partial name="_DatatablesSheetFiles" />

<style>
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a2b6d 0%, #0b1437 100%);
        color: var(--gold);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        border: 2px solid var(--gold);
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        margin: 2rem 0;
        background: #f8f9fa;
        border-radius: 14px;
        border: 2px dashed #dee2e6;
    }

    .empty-state-icon {
        font-size: 4rem;
        color: var(--navy);
        opacity: 0.3;
        margin-bottom: 1.5rem;
    }

    .empty-state h5 {
        color: var(--navy);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #6c757d;
        margin-bottom: 1.5rem;
    }
</style>

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-people-fill"></i> Employee Management
        </h1>
        <p class="text-muted">Manage employees, assign positions, and track roles</p>
    </div>
    <div class="header-actions">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addEmployeeModal">
            <i class="bi bi-plus-circle me-2"></i>Add Employee
        </button>
    </div>
</div>

<div class="page-content">
    <!-- Success Alert -->
    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Alert -->
    @if (!string.IsNullOrEmpty(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Error!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search and Filter -->
    <div class="search-filter-area">
        <div class="search-group">
            <label for="searchInput">Search Employees:</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Search by name, email, or position...">
        </div>
    </div>

    <!-- Employees DataTable -->
    <div class="datatable-container">
        @if (Model.Employees.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="bi bi-person-slash"></i>
                </div>
                <h5>No Employees Found</h5>
                <p class="text-muted">Start by adding your first employee to the system</p>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addEmployeeModal">
                    <i class="bi bi-plus-circle me-2"></i>Add First Employee
                </button>
            </div>
        }
        else
        {
            <table id="employeesTable" class="table table-hover">
                <thead>
                    <tr>
                        <th class="col-1">#</th>
                        <th class="col-2">Name</th>
                        <th class="col-2">Email</th>
                        <th class="col-2">Phone</th>
                        <th class="col-2">Position(s)</th>
                        <th class="col-2">Created Date</th>
                        <th class="col-1">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int counter = 1;
                    }
                    @foreach (var employee in Model.Employees)
                    {
                        <tr>
                            <td>@counter</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-2">
                                        @(employee.FirstName?.Substring(0, 1))@(employee.LastName?.Substring(0, 1))
                                    </div>
                                    <div>
                                        <strong>@employee.FirstName @employee.LastName</strong>
                                    </div>
                                </div>
                            </td>
                            <td>@employee.Email</td>
                            <td>@(employee.Phone ?? "-")</td>
                            <td>
                                @if (employee.Positions != null && employee.Positions.Any())
                                {
                                    @foreach (var position in employee.Positions)
                                    {
                                        <span class="badge bg-info-subtle text-info me-1 mb-1">
                                            <i class="bi bi-briefcase-fill me-1"></i>@position
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No position assigned</span>
                                }
                            </td>
                            <td>@DateTime.Now.ToLongTimeString()</td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button" class="btn btn-outline-primary btn-edit-employee" 
                                            data-id="@employee.Id" 
                                            data-firstname="@employee.FirstName" 
                                            data-lastname="@employee.LastName"
                                            data-email="@employee.Email"
                                            data-phone="@employee.Phone"
                                            title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-success btn-assign-position" 
                                            data-id="@employee.Id" 
                                            data-name="@employee.FirstName @employee.LastName"
                                            title="Assign Position">
                                        <i class="bi bi-person-badge-fill"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-danger btn-delete-employee" 
                                            data-id="@employee.Id" 
                                            data-name="@employee.FirstName @employee.LastName"
                                            title="Delete">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        counter++;
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Add Employee Modal -->
<div class="modal fade" id="addEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-person-plus-fill me-2"></i>Add Employee
                    </h5>
                    <small>Create new employee account</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="AddEmployee">
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-person me-1"></i>First Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" name="EmployeeModel.FirstName" placeholder="Enter first name" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-person me-1"></i>Last Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" name="EmployeeModel.LastName" placeholder="Enter last name" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-envelope me-1"></i>Email <span class="text-danger">*</span>
                        </label>
                        <input type="email" class="form-control" name="EmployeeModel.Email" placeholder="Enter email address" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-telephone me-1"></i>Phone <span class="text-danger">*</span>
                        </label>
                        <input type="tel" class="form-control" name="EmployeeModel.Phone" placeholder="Enter phone number" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-building me-1"></i>Department
                        </label>
                        <input type="text" class="form-control" name="EmployeeModel.Department" placeholder="Enter department (optional)">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Create Employee
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Employee Modal -->
<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-pencil-square me-2"></i>Edit Employee
                    </h5>
                    <small>Update employee information</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="UpdateEmployee">
                <div class="modal-body">
                    <input type="hidden" name="EmployeeModel.Id" id="editEmployeeId">
                    
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-person me-1"></i>First Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" name="EmployeeModel.FirstName" id="editFirstName" placeholder="Enter first name" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-person me-1"></i>Last Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" name="EmployeeModel.LastName" id="editLastName" placeholder="Enter last name" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-envelope me-1"></i>Email <span class="text-danger">*</span>
                        </label>
                        <input type="email" class="form-control" name="EmployeeModel.Email" id="editEmail" placeholder="Enter email address" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-telephone me-1"></i>Phone <span class="text-danger">*</span>
                        </label>
                        <input type="tel" class="form-control" name="EmployeeModel.Phone" id="editPhone" placeholder="Enter phone number" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Update Employee
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Assign Position Modal -->
<div class="modal fade" id="assignPositionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-person-badge-fill me-2"></i>Assign Position
                    </h5>
                    <small id="assignEmployeeName">Assign position to employee</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="AssignPosition">
                <div class="modal-body">
                    <input type="hidden" name="EmployeePositionModel.EmployeeId" id="assignEmployeeId">
                    
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <strong>Note:</strong> Selecting a position will automatically link it to this employee. Positions determine access rights and responsibilities.
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">
                            <i class="bi bi-briefcase me-1"></i>Select Position <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" name="EmployeePositionModel.PositionId" required>
                            <option value="">-- Select a position --</option>
                            @foreach (var position in Model.AvailablePositions)
                            {
                                <option value="@position.Id">@position.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Assign Position
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_DatatablesScriptsFiles" />
    <script src="~/js/appmain.js"></script>
    
    <script>
        $(document).ready(function() {
            // Initialize DataTable if employees exist
            @if (Model.Employees.Count > 0)
            {
                <text>
                var employeesTable = $('#employeesTable').DataTable({
                    responsive: true,
                    order: [[1, 'asc']],
                    language: {
                        emptyTable: 'No employees found',
                        zeroRecords: 'No matching employees found'
                    }
                });

                // Bind search input
                $('#searchInput').on('keyup', function () {
                    employeesTable.search(this.value).draw();
                });
                </text>
            }

            // Handle Edit button click
            $(document).on('click', '.btn-edit-employee', function() {
                var id = $(this).data('id');
                var firstName = $(this).data('firstname');
                var lastName = $(this).data('lastname');
                var email = $(this).data('email');
                var phone = $(this).data('phone');

                $('#editEmployeeId').val(id);
                $('#editFirstName').val(firstName);
                $('#editLastName').val(lastName);
                $('#editEmail').val(email);
                $('#editPhone').val(phone);

                var editModal = new bootstrap.Modal(document.getElementById('editEmployeeModal'));
                editModal.show();
            });

            // Handle Assign Position button click
            $(document).on('click', '.btn-assign-position', function() {
                var id = $(this).data('id');
                var name = $(this).data('name');

                $('#assignEmployeeId').val(id);
                $('#assignEmployeeName').text('Assign position to ' + name);

                var assignModal = new bootstrap.Modal(document.getElementById('assignPositionModal'));
                assignModal.show();
            });

            // Handle Delete button click
            $(document).on('click', '.btn-delete-employee', function() {
                var id = $(this).data('id');
                var name = $(this).data('name');

                Swal.fire({
                    title: 'Delete Employee?',
                    html: 'Are you sure you want to delete <strong>' + name + '</strong>?<br><small class="text-muted">This action cannot be undone.</small>',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="bi bi-trash me-1"></i>Yes, delete',
                    cancelButtonText: '<i class="bi bi-x-circle me-1"></i>Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Create a form and submit it
                        var form = $('<form method="post" action="?handler=DeleteEmployee"></form>');
                        form.append('<input type="hidden" name="id" value="' + id + '">');
                        form.append('<input type="hidden" name="__RequestVerificationToken" value="' + $('input[name="__RequestVerificationToken"]').val() + '">');
                        $('body').append(form);
                        form.submit();
                    }
                });
            });
        });
    </script>
}
