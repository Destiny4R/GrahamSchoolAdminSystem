@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.termly_registeration.indexModel
@{
    ViewData["Title"] = "Termly Registration";
    await Permissions.InitializeAsync(User);
}
@section Sheets {
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <partial name="_DatatablesSheetFiles" />
}
<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-list-check"></i> Termly Registration
        </h1>
        <p class="text-white-50">Manage students term registrations</p>
    </div>
    <div class="header-actions">
        <div class="btn-group">
            @if (Permissions.CanCreate)
            {
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#batchExcelModal">
                <i class="bi bi-file-earmark-excel me-1"></i> Excel Upload
            </button>
            <a asp-page="batch-registration" class="btn btn-primary">Batch Registration</a>
            <a asp-page="upsert" class="btn btn-primary">Single Registration</a>
            }
            @if (Permissions.CanDelete)
            {
            <button id="bulkDeleteBtn" class="btn btn-danger" style="display:none;">
                <i class="bi bi-trash"></i> Delete Selected (<span id="selectedCount">0</span>)
            </button>
            }
        </div>
    </div>
</div>
<div class="page-content">
    <!-- Success Alert -->
    @if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Alert -->
    @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Error!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Filters -->
    <div class="row mb-4">
        <div class="col-md-3">
            <label for="term" class="form-label">Term</label>
            <select class="form-select" id="term" asp-items="@Model.Selections.Terms">
                <option value="">---Select Term---</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="session" class="form-label">Academic Session</label>
            <select class="form-select" id="session" asp-items="@Model.Selections.AcademicSession">
                <option value="">---Select Session---</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="schoolclass" class="form-label">Class</label>
            <select class="form-select" id="schoolclass" asp-items="@Model.Selections.SchoolClasses">
                <option value="">---Select Class---</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="subclass" class="form-label">Sub Class</label>
            <select class="form-select" id="subclass" asp-items="@Model.Selections.SubClass">
                <option value="">---Select Sub Class---</option>
            </select>
        </div>
    </div>

    <!-- DataTable Container -->
    <div class="datatable-container">
        <table id="studentsTermRegTable" class="table table-hover" style="font-family:'Playfair Display', serif;">
            <thead>
                <tr>
                    <th style="width: 50px;">
                        <input type="checkbox" id="selectAll" class="form-check-input" title="Select All" />
                    </th>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Reg. Number</th>
                    <th>Term</th>
                    <th>Session</th>
                    <th>Class</th>
                    <th>Created Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<!-- Batch Excel Upload Modal -->
<div class="modal fade" id="batchExcelModal" tabindex="-1" aria-labelledby="batchExcelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="batchExcelModalLabel">
                    <i class="bi bi-file-earmark-excel me-2"></i>Batch Registration via Excel Upload
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Upload an Excel file containing <strong>only student registration numbers</strong> (one per row in the first column).
                    All students will be registered into the selected Term, Session, Class, and Sub-Class.
                </div>
                <form id="batchExcelForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="batchSession" class="form-label">Academic Session <span class="text-danger">*</span></label>
                            <select class="form-select" id="batchSession" required asp-items="@Model.Selections.AcademicSession">
                                <option value="">---Select Session---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="batchTerm" class="form-label">Term <span class="text-danger">*</span></label>
                            <select class="form-select" id="batchTerm" required asp-items="@Model.Selections.Terms">
                                <option value="">---Select Term---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="batchClass" class="form-label">Class <span class="text-danger">*</span></label>
                            <select class="form-select" id="batchClass" required asp-items="@Model.Selections.SchoolClasses">
                                <option value="">---Select Class---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="batchSubClass" class="form-label">Sub Class <span class="text-danger">*</span></label>
                            <select class="form-select" id="batchSubClass" required asp-items="@Model.Selections.SubClass">
                                <option value="">---Select Sub Class---</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="batchExcelFile" class="form-label">Excel File (.xlsx) <span class="text-danger">*</span></label>
                            <input type="file" class="form-control" id="batchExcelFile" accept=".xlsx,.xls" required />
                            <div class="form-text">The file should contain student registration numbers in the first column.</div>
                        </div>
                    </div>
                </form>
                <!-- Results Container (hidden by default) -->
                <div id="batchResultsContainer" class="mt-3" style="display:none;">
                    <hr />
                    <h6><i class="bi bi-clipboard-data me-2"></i>Registration Results</h6>
                    <div id="batchResultsSummary"></div>
                    <div id="batchResultsErrors" class="mt-2" style="display:none;">
                        <p class="text-danger fw-bold mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Failed Registrations:</p>
                        <div id="batchErrorsList" class="small" style="max-height: 200px; overflow-y: auto;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>Close
                </button>
                <button type="button" class="btn btn-success" id="btnSubmitBatchExcel">
                    <i class="bi bi-upload me-1"></i>Upload & Register
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_DatatablesScriptsFiles" />
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/lib/jquery.blockui/jquery.blockui.min.js"></script>
    <script>
        window.userPermissions = {
            canCreate: @Json.Serialize(Permissions.CanCreate),
            canEdit: @Json.Serialize(Permissions.CanEdit),
            canDelete: @Json.Serialize(Permissions.CanDelete)
        };
    </script>
    <script src="~/js/appmain.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function(){
            let tabledata = null;

            // Initialize DataTable
            if ($("#studentsTermRegTable").length) {
                tabledata = $('#studentsTermRegTable').DataTable({
                    serverSide: true,
                    processing: true,
                    searching: true,
                    paging: true,
                    info: true,
                    responsive: true,
                    ajax: {
                        url: "/home/GetTermRegistrationsDataTable",
                        type: "POST",
                        dataType: 'json',
                        data: function (d) {
                            // Get filter values
                            const term = $('#term').val();
                            const session = $('#session').val();
                            const schoolclass = $('#schoolclass').val();
                            const subclass = $('#subclass').val();

                            // Prepare DataTable form data with filters
                            const formData = new FormData();
                            formData.append('draw', d.draw);
                            formData.append('start', d.start || 0);
                            formData.append('length', d.length || 10);
                            formData.append('search[value]', d.search?.value || '');
                            if (d.order && d.order.length > 0) {
                                formData.append('order[0][column]', d.order[0].column);
                                formData.append('order[0][dir]', d.order[0].dir);
                            }
                            formData.append('term', term);
                            formData.append('session', session);
                            formData.append('schoolclass', schoolclass);
                            formData.append('subclass', subclass);

                            return formData;
                        },
                        processData: false,
                        contentType: false
                    },
                    columns: [
                        {
                            data: null,
                            orderable: false,
                            searchable: false,
                            autoWidth: true,
                            width: '50px',
                            render: function (data, type, row) {
                                if (row.hasPayment) {
                                    return '<i class="bi bi-lock-fill text-warning" title="Payment recorded — protected"></i>';
                                }
                                return `<input type="checkbox" class="form-check-input row-checkbox" value="${row.id}" />`;
                            }
                        },
                        {
                            data: null,
                            orderable: false,
                            searchable: false,
                            autoWidth: true,
                            render: function (data, type, row, meta) {
                                return meta.settings._iDisplayStart + meta.row + 1;
                            }
                        },
                        { data: "name", autoWidth: true },
                        { data: "regnumber", autoWidth: true },
                        { data: "term", autoWidth: true },
                        { data: "session", autoWidth: true },
                        { data: "schoolclass", autoWidth: true },
                        {
                            data: "createdate",
                            autoWidth: true,
                            render: function (data, type, row) {
                                if (data != null) {
                                    let date = new Date(data);
                                    return date.toLocaleString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
                                }
                                return "N/A";
                            }
                        },
                        {
                            data: null,
                            orderable: false,
                            searchable: false,
                            render: function (data, type, row) {
                                if (row.hasPayment) {
                                    return '<span class="badge bg-warning text-dark" title="Payment recorded — cannot edit or delete"><i class="bi bi-lock-fill me-1"></i>Locked</span>';
                                }
                                var perms = window.userPermissions || {};
                                var items = '';
                                if (perms.canEdit) {
                                    items += '<li><a class="dropdown-item" href="/admin/termly-registeration/upsert?id=' + row.id + '"><i class="bi bi-pencil-square"></i> Edit</a></li>';
                                }
                                if (perms.canDelete) {
                                    items += '<li><button class="dropdown-item btn-delete-single" data-id="' + row.id + '"><i class="bi bi-trash"></i> Delete</button></li>';
                                }
                                if (!items) return '';
                                return '<div class="dropdown">' +
                                    '<button class="btn btn-dark btn-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">' +
                                    '<i class="bi bi-three-dots-vertical me-1"></i></button>' +
                                    '<ul class="dropdown-menu">' + items + '</ul></div>';
                            }
                        }
                    ]
                });
            }

            // Select All Checkbox
            $(document).on('click', '#selectAll', function () {
                const isChecked = $(this).is(':checked');
                $('.row-checkbox').prop('checked', isChecked);
                updateBulkDeleteButton();
            });

            // Individual Row Checkbox
            $(document).on('click', '.row-checkbox', function () {
                const totalCheckboxes = $('.row-checkbox').length;
                const checkedCheckboxes = $('.row-checkbox:checked').length;

                if (totalCheckboxes === checkedCheckboxes) {
                    $('#selectAll').prop('checked', true);
                } else {
                    $('#selectAll').prop('checked', false);
                }
                updateBulkDeleteButton();
            });

            // Update Bulk Delete Button Visibility
            function updateBulkDeleteButton() {
                const selectedCount = $('.row-checkbox:checked').length;
                $('#selectedCount').text(selectedCount);

                if (selectedCount > 0) {
                    $('#bulkDeleteBtn').show();
                } else {
                    $('#bulkDeleteBtn').hide();
                }
            }

            // Bulk Delete
            $(document).on('click', '#bulkDeleteBtn', function () {
                const selectedIds = [];
                $('.row-checkbox:checked').each(function () {
                    selectedIds.push(parseInt($(this).val()));
                });

                if (selectedIds.length === 0) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Warning',
                        text: 'Please select at least one record to delete'
                    });
                    return;
                }

                const swalWithBootstrapButtons = Swal.mixin({
                    customClass: {
                        confirmButton: "btn btn-danger rounded-pill btn-sm",
                        cancelButton: "btn btn-secondary rounded-pill btn-sm me-2"
                    },
                    buttonsStyling: false
                });

                swalWithBootstrapButtons.fire({
                    title: "Delete Confirmation",
                    html: `Are you sure you want to delete <strong>${selectedIds.length}</strong> selected registration(s)? This action cannot be undone.`,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes, Delete",
                    cancelButtonText: "No, Cancel",
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            type: "POST",
                            url: '/api/v1/termregistration/deletemultiple',
                            contentType: 'application/json',
                            data: JSON.stringify(selectedIds),
                            beforeSend: function () {
                                $.blockUI({
                                    message: '<div class="spinner-border text-light" role="status"><span class="visually-hidden">Loading...</span></div>',
                                    css: {
                                        backgroundColor: 'transparent',
                                        border: 'none'
                                    },
                                    overlayCSS: {
                                        backgroundColor: '#000',
                                        opacity: 0.6
                                    }
                                });
                            },
                            success: function (response) {
                                $.unblockUI();
                                if (response.success) {
                                    swalWithBootstrapButtons.fire({
                                        title: 'Success!',
                                        text: response.message,
                                        icon: 'success'
                                    });
                                    tabledata.ajax.reload(null, false);
                                    $('#selectAll').prop('checked', false);
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Error',
                                        text: response.message
                                    });
                                }
                            },
                            error: function (xhr, status, error) {
                                $.unblockUI();
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: 'An error occurred while deleting records. Please try again.'
                                });
                            }
                        });
                    }
                });
            });

            // Single Delete
            $(document).on('click', '.btn-delete-single', function () {
                const id = $(this).data('id');

                const swalWithBootstrapButtons = Swal.mixin({
                    customClass: {
                        confirmButton: "btn btn-danger rounded-pill btn-sm",
                        cancelButton: "btn btn-secondary rounded-pill btn-sm me-2"
                    },
                    buttonsStyling: false
                });

                swalWithBootstrapButtons.fire({
                    title: "Delete Confirmation",
                    text: 'Are you sure you want to remove this record?',
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes, Delete",
                    cancelButtonText: "No, Cancel",
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            type: "DELETE",
                            url: `/api/v1/termregistration/${id}`,
                            contentType: 'application/json',
                            beforeSend: function () {
                                $.blockUI({
                                    message: '<div class="spinner-border text-light" role="status"><span class="visually-hidden">Loading...</span></div>',
                                    css: {
                                        backgroundColor: 'transparent',
                                        border: 'none'
                                    },
                                    overlayCSS: {
                                        backgroundColor: '#000',
                                        opacity: 0.6
                                    }
                                });
                            },
                            success: function (response) {
                                $.unblockUI();
                                if (response.success) {
                                    swalWithBootstrapButtons.fire({
                                        title: 'Success!',
                                        text: response.message,
                                        icon: 'success'
                                    });
                                    tabledata.ajax.reload(null, false);
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Error',
                                        text: response.message
                                    });
                                }
                            },
                            error: function () {
                                $.unblockUI();
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: 'An error occurred while deleting the record.'
                                });
                            }
                        });
                    }
                });
            });

            // Filter Logic - Only apply when all filters are selected
            $('#term, #session, #schoolclass, #subclass').on('change', function () {
                const term = $('#term').val();
                const session = $('#session').val();
                const schoolclass = $('#schoolclass').val();
                const subclass = $('#subclass').val();

                // Only reload table if all filters are selected
                if (term && session && schoolclass && subclass) {
                    // Reset pagination to first page when filtering
                    tabledata.page(0).draw('page');
                } else {
                    // If filters are cleared, also show all records
                    if (!term && !session && !schoolclass && !subclass) {
                        tabledata.page(0).draw('page');
                    }
                }
            });

            // Clear filters function
            function clearFilters() {
                $('#term').val('');
                $('#session').val('');
                $('#schoolclass').val('');
                $('#subclass').val('');
                tabledata.ajax.reload();
            }

            // ========================================================
            // Batch Excel Upload
            // ========================================================
            $('#btnSubmitBatchExcel').on('click', function () {
                var sessionId = $('#batchSession').val();
                var term = $('#batchTerm').val();
                var classId = $('#batchClass').val();
                var subClassId = $('#batchSubClass').val();
                var fileInput = document.getElementById('batchExcelFile');
                var file = fileInput.files[0];

                if (!sessionId) { Swal.fire('Warning', 'Please select an Academic Session', 'warning'); return; }
                if (!term) { Swal.fire('Warning', 'Please select a Term', 'warning'); return; }
                if (!classId) { Swal.fire('Warning', 'Please select a Class', 'warning'); return; }
                if (!subClassId) { Swal.fire('Warning', 'Please select a Sub Class', 'warning'); return; }
                if (!file) { Swal.fire('Warning', 'Please select an Excel file', 'warning'); return; }

                var formData = new FormData();
                formData.append('excelFile', file);
                formData.append('sessionId', sessionId);
                formData.append('term', term);
                formData.append('schoolClassId', classId);
                formData.append('schoolSubclassId', subClassId);

                var $btn = $(this);
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Processing...');
                $('#batchResultsContainer').hide();

                $.ajax({
                    url: '/api/v1/termregistration/batch-excel',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (resp) {
                        $btn.prop('disabled', false).html('<i class="bi bi-upload me-1"></i>Upload & Register');

                        if (resp.success) {
                            var summaryHtml = '<div class="alert alert-success mb-0">' +
                                '<i class="bi bi-check-circle-fill me-2"></i>' +
                                '<strong>' + resp.successCount + '</strong> registered successfully';
                            if (resp.failureCount > 0) {
                                summaryHtml += ', <strong class="text-danger">' + resp.failureCount + '</strong> failed';
                            }
                            summaryHtml += ' out of <strong>' + resp.total + '</strong> total.</div>';
                            $('#batchResultsSummary').html(summaryHtml);

                            if (resp.errors && resp.errors.length > 0) {
                                var errorsHtml = '<ul class="list-group list-group-flush">';
                                resp.errors.forEach(function (err) {
                                    errorsHtml += '<li class="list-group-item list-group-item-danger py-1 px-2"><small>' + err + '</small></li>';
                                });
                                errorsHtml += '</ul>';
                                $('#batchErrorsList').html(errorsHtml);
                                $('#batchResultsErrors').show();
                            } else {
                                $('#batchResultsErrors').hide();
                            }

                            $('#batchResultsContainer').show();

                            // Reload the DataTable
                            if (tabledata) {
                                tabledata.ajax.reload(null, false);
                            }
                        } else {
                            Swal.fire('Error', resp.message, 'error');
                        }
                    },
                    error: function () {
                        $btn.prop('disabled', false).html('<i class="bi bi-upload me-1"></i>Upload & Register');
                        Swal.fire('Error', 'An unexpected error occurred during batch registration', 'error');
                    }
                });
            });

            // Reset modal on close
            $('#batchExcelModal').on('hidden.bs.modal', function () {
                $('#batchExcelForm')[0].reset();
                $('#batchResultsContainer').hide();
                $('#batchResultsErrors').hide();
            });
        });
    </script>
}