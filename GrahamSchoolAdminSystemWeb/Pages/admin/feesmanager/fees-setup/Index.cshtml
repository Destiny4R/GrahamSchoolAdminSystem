@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.feesmanager.fees_setup.IndexModel
@{
    ViewData["Title"] = "Fees Setup - Graham School Admin System";
}

<link rel="stylesheet" href="~/css/shared-components.css" />
<link rel="stylesheet" href="~/css/admin-pages.css" />
<partial name="_DatatablesSheetFiles" />

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-cash-coin"></i> Fees Setup Management
        </h1>
        <p class="text-muted">Manage termly fees for school classes</p>
    </div>
    <div class="header-actions">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#feesSetupModal" onclick="resetForm()">
            <i class="bi bi-plus-circle me-2"></i>Add Fees Setup
        </button>
    </div>
</div>

<div class="page-content">
    <!-- Success Alert -->
    @if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Alert -->
    @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Error!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- DataTable Container -->
    <div class="datatable-container">
        <table id="feesSetupTable" class="table table-hover table-sm">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Term</th>
                    <th>Academic Session</th>
                    <th>Class</th>
                    <th>Amount</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<!-- Add/E Modal -->
<div class="modal fade" id="feesSetupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-cash-coin me-2"></i><span id="modalTitle">Add Fees Setup</span>
                    </h5>
                    <small>Create new fees set up information</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post">
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="FeesSetupModel.SchoolClassId">
                            <i class="bi bi-building me-1"></i>School Class <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="schoolClassId" asp-for="FeesSetupModel.SchoolClassId" required asp-items="@Model.Selections.SchoolClasses">
                            <option selected>-- Select a class --</option>
                        </select>
                        <span class="invalid-feedback" asp-validation-for="FeesSetupModel.SchoolClassId"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="FeesSetupModel.SessionId">
                            <i class="bi bi-calendar-event me-1"></i>Academic Session <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" asp-for="FeesSetupModel.SessionId" required asp-items="@Model.Selections.AcademicSession">
                            <option disabled selected>-- Select a session --</option>
                        </select>
                        <span class="invalid-feedback" asp-validation-for="FeesSetupModel.SessionId"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="FeesSetupModel.Term">
                            <i class="bi bi-hourglass-split me-1"></i>Term <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" asp-for="FeesSetupModel.Term" required asp-items="@Model.Selections.Terms">
                            <option disabled selected>-- Select a term --</option>
                        </select>
                        <span class="invalid-feedback" asp-validation-for="FeesSetupModel.Term"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="FeesSetupModel.Amount">
                            <i class="bi bi-currency-dollar me-1"></i>Amount <span class="text-danger">*</span>
                        </label>
                        <input type="number" class="form-control" asp-for="FeesSetupModel.Amount"
                               placeholder="Enter fee amount" step="0.01" min="0" required>
                            <span class="invalid-feedback" asp-validation-for="FeesSetupModel.Amount"></span>
                        </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i><span id="submitBtnText">Save</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


<!--Edit Modal -->
<div class="modal fade" id="feesSetupEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title">
                        <i class="bi bi-cash-coin me-2"></i><span id="modalTitle">Edit Fees Setup</span>
                    </h5>
                    <small>Update fees set up information</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post">
                <div class="modal-body">
                    <input type="hidden" id="feesSetupId" name="id" />

                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="FeesSetupModel.SchoolClassId">
                            <i class="bi bi-building me-1"></i>School Class <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="schoolClassId" asp-for="FeesSetupModel.SchoolClassId" required asp-items="@Model.Selections.SchoolClasses">
                            <option selected>-- Select a class --</option>
                        </select>
                        <span class="invalid-feedback" asp-validation-for="FeesSetupModel.SchoolClassId"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="FeesSetupModel.SessionId">
                            <i class="bi bi-calendar-event me-1"></i>Academic Session <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" asp-for="FeesSetupModel.SessionId" required asp-items="@Model.Selections.AcademicSession">
                            <option disabled selected>-- Select a session --</option>
                        </select>
                        <span class="invalid-feedback" asp-validation-for="FeesSetupModel.SessionId"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="FeesSetupModel.Term">
                            <i class="bi bi-hourglass-split me-1"></i>Term <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" asp-for="FeesSetupModel.Term" required asp-items="@Model.Selections.Terms">
                            <option disabled selected>-- Select a term --</option>
                        </select>
                        <span class="invalid-feedback" asp-validation-for="FeesSetupModel.Term"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label" asp-for="FeesSetupModel.Amount">
                            <i class="bi bi-currency-dollar me-1"></i>Amount <span class="text-danger">*</span>
                        </label>
                        <input type="number" class="form-control" asp-for="FeesSetupModel.Amount"
                               placeholder="Enter fee amount" step="0.01" min="0" required>
                        <span class="invalid-feedback" asp-validation-for="FeesSetupModel.Amount"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i><span id="submitBtnText">Save</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
    <partial name="_DatatablesScriptsFiles" />

    <script src="~/js/appmain.js"></script>
}