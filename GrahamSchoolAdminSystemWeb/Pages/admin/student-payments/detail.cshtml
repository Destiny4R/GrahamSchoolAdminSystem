@page "{id:int}"
@model GrahamSchoolAdminSystemWeb.Pages.admin.student_payments.detailModel
@inject GrahamSchoolAdminSystemWeb.Helpers.ViewPermissionService Permissions
@{
    ViewData["Title"] = "Payment Detail";
    await Permissions.InitializeAsync(User);
}

@section Sheets{
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link href="~/lib/sweetalert2/sweetalert2.css" rel="stylesheet" />
    <style>
        .detail-label { font-weight: 600; color: #555; }
        .evidence-img { max-width: 400px; max-height: 400px; border: 1px solid #ddd; border-radius: 8px; cursor: pointer; }
        .state-badge-lg { font-size: 1rem; padding: 0.5em 1em; }
    </style>
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-file-earmark-text"></i> Payment Detail</h1>
        <p class="text-white">View payment information and manage approval state</p>
    </div>
    <div class="header-actions">
        <a asp-page="/admin/student-payments/index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Payments
        </a>
        @if (Model.Payment != null && (Model.Payment.State == "Pending" || Model.Payment.State == "Approved"))
        {
            <a href="/admin/student-payments/receipt/@Model.Payment.PaymentId" class="btn btn-outline-success">
                <i class="bi bi-receipt me-2"></i>View Receipt
            </a>
        }
    </div>
</div>

<div class="page-content">
    @if (Model.Payment != null)
    {
        var payment = Model.Payment;

        var stateCls = payment.State switch
        {
            "Approved" => "bg-success",
            "Pending" => "bg-warning text-dark",
            "Rejected" => "bg-danger",
            "Cancelled" => "bg-dark",
            _ => "bg-secondary"
        };

        <!-- Payment Info Card -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Payment Information</h5>
                <span class="badge @stateCls state-badge-lg">@payment.State</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <span class="detail-label">Reference:</span>
                        <p class="mb-1">@payment.Reference</p>
                    </div>
                    <div class="col-md-4">
                        <span class="detail-label">Student:</span>
                        <p class="mb-1">@payment.StudentName</p>
                    </div>
                    <div class="col-md-4">
                        <span class="detail-label">Admission No:</span>
                        <p class="mb-1">@payment.AdmissionNo</p>
                    </div>
                    <div class="col-md-4">
                        <span class="detail-label">Class:</span>
                        <p class="mb-1">@payment.ClassName</p>
                    </div>
                    <div class="col-md-4">
                        <span class="detail-label">Session:</span>
                        <p class="mb-1">@payment.SessionName</p>
                    </div>
                    <div class="col-md-4">
                        <span class="detail-label">Term:</span>
                        <p class="mb-1">@payment.TermName</p>
                    </div>
                    <div class="col-md-4">
                        <span class="detail-label">Payment Date:</span>
                        <p class="mb-1">@payment.PaymentDate.ToString("dd/MM/yyyy hh:mm tt")</p>
                    </div>
                    <div class="col-md-4">
                        <span class="detail-label">Total Amount:</span>
                        <p class="mb-1 fw-bold text-primary">@GrahamSchoolAdminSystemAccess.SD.ToNaira(payment.TotalAmount)</p>
                    </div>
                    <div class="col-md-4">
                        <span class="detail-label">Status:</span>
                        <p class="mb-1">
                            <span class="badge @(payment.Status == "Completed" ? "bg-success" : "bg-warning")">@payment.Status</span>
                        </p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(payment.Narration))
                {
                    <hr />
                    <div>
                        <span class="detail-label"><i class="bi bi-chat-left-text me-1"></i>Narration:</span>
                        <p class="mb-0">@payment.Narration</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(payment.RejectMessage))
                {
                    <hr />
                    <div class="alert alert-danger mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Rejection Reason:</strong> @payment.RejectMessage
                    </div>
                }
            </div>
        </div>

        <!-- Evidence Card -->
        @if (!string.IsNullOrEmpty(payment.EvidenceFilePath))
        {
            <div class="card mb-4">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-paperclip me-2"></i>Payment Evidence</h5>
                </div>
                <div class="card-body text-center">
                    @if (payment.EvidenceFilePath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                    {
                        <a href="@payment.EvidenceFilePath" target="_blank" class="btn btn-outline-primary btn-lg">
                            <i class="bi bi-file-earmark-pdf me-2"></i>View PDF Evidence
                        </a>
                    }
                    else
                    {
                        <a href="@payment.EvidenceFilePath" target="_blank">
                            <img src="@payment.EvidenceFilePath" alt="Payment Evidence" class="evidence-img" />
                        </a>
                        <div class="mt-2">
                            <a href="@payment.EvidenceFilePath" target="_blank" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-box-arrow-up-right me-1"></i>Open Full Size
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Line Items Card -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Payment Items</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Category</th>
                            <th>Item</th>
                            <th class="text-end">Amount Paid</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = 1; }
                        @foreach (var line in payment.LineItems)
                        {
                            <tr>
                                <td>@(idx++)</td>
                                <td>@line.CategoryName</td>
                                <td>@line.ItemName</td>
                                <td class="text-end">@GrahamSchoolAdminSystemAccess.SD.ToNaira(line.AmountPaid)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-primary">
                            <td colspan="3" class="text-end fw-bold">Total:</td>
                            <td class="text-end fw-bold">@GrahamSchoolAdminSystemAccess.SD.ToNaira(payment.TotalAmount)</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Approval Actions Card -->
        @if (Permissions.CanReport)
        {
            <div class="card mb-4" id="approvalActionsCard">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-shield-check me-2"></i>Approval Actions</h5>
                </div>
                <div class="card-body">
                    @if (payment.State == "Pending")
                    {
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-success btn-action" data-state="2" data-id="@payment.PaymentId">
                                <i class="bi bi-check-circle me-2"></i>Approve
                            </button>
                            <button type="button" class="btn btn-danger btn-action" data-state="3" data-id="@payment.PaymentId">
                                <i class="bi bi-x-circle me-2"></i>Reject
                            </button>
                            <button type="button" class="btn btn-dark btn-action" data-state="4" data-id="@payment.PaymentId">
                                <i class="bi bi-slash-circle me-2"></i>Cancel
                            </button>
                        </div>
                    }
                    else if (payment.State == "Approved")
                    {
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-dark btn-action" data-state="4" data-id="@payment.PaymentId">
                                <i class="bi bi-slash-circle me-2"></i>Cancel
                            </button>
                        </div>
                    }
                    else if (payment.State == "Rejected" || payment.State == "Cancelled")
                    {
                        <div class="alert alert-secondary mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            This payment has been <strong>@payment.State</strong>. The cashier can reprocess this payment from the Make Payment page.
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            Payment not found.
        </div>
    }
</div>

@section Scripts {
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.btn-action').on('click', function () {
                var state = parseInt($(this).data('state'));
                var paymentId = $(this).data('id');
                var stateNames = { 2: 'Approve', 3: 'Reject', 4: 'Cancel' };
                var stateColors = { 2: 'success', 3: 'error', 4: 'warning' };
                var actionName = stateNames[state] || 'Update';

                if (state === 3) {
                    // Reject — require a reason
                    Swal.fire({
                        title: 'Reject Payment',
                        input: 'textarea',
                        inputLabel: 'Rejection reason (required)',
                        inputPlaceholder: 'Enter reason for rejection...',
                        inputAttributes: { maxlength: 120 },
                        inputValidator: function (value) {
                            if (!value || !value.trim()) return 'You must provide a rejection reason';
                        },
                        showCancelButton: true,
                        confirmButtonText: 'Reject Payment',
                        confirmButtonColor: '#dc3545'
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            submitStateUpdate(paymentId, state, result.value.trim());
                        }
                    });
                } else {
                    Swal.fire({
                        title: actionName + ' Payment?',
                        text: 'Are you sure you want to ' + actionName.toLowerCase() + ' this payment?',
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, ' + actionName,
                        confirmButtonColor: state === 2 ? '#198754' : '#333'
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            submitStateUpdate(paymentId, state, null);
                        }
                    });
                }
            });

            function submitStateUpdate(paymentId, state, rejectMessage) {
                $.ajax({
                    url: '/api/v1/studentpayments/' + paymentId + '/update-state',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ paymentState: state, rejectMessage: rejectMessage }),
                    success: function (resp) {
                        if (resp.success) {
                            Swal.fire({
                                title: 'Updated!',
                                text: resp.message,
                                icon: 'success'
                            }).then(function () {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', resp.message, 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Error', 'An unexpected error occurred', 'error');
                    }
                });
            }
        });
    </script>
}
