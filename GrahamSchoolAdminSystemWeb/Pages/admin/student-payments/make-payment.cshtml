@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.student_payments.make_paymentModel
@inject GrahamSchoolAdminSystemWeb.Helpers.ViewPermissionService Permissions
@{
    ViewData["Title"] = "Make Payment";
    await Permissions.InitializeAsync(User);
}

@section Sheets{
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link href="~/lib/sweetalert2/sweetalert2.css" rel="stylesheet" />
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-credit-card"></i> Make Payment
        </h1>
        <p class="text-white">Select class, payment category and admission number to process payment</p>
    </div>
    <div class="header-actions">
        <a asp-page="/admin/student-payments/index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back
        </a>
    </div>
</div>

<div class="page-content">
    <!-- Step 1: Lookup Form -->
    <div class="card" id="lookupCard">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0 pl-5"><i class="bi bi-search me-2"></i>Step 1: Find Student & Payment Items</h5>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="lookupClass" class="form-label">Class</label>
                    <select id="lookupClass" class="form-select">
                        <option value="">-- Select Class --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="lookupCategory" class="form-label">Payment Category</label>
                    <select id="lookupCategory" class="form-select">
                        <option value="">-- Select Category --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="lookupAdmissionNo" class="form-label">Admission Number</label>
                    <input type="text" id="lookupAdmissionNo" class="form-control" placeholder="Enter admission no..." />
                </div>
                <div class="col-md-3">
                    <button type="button" id="btnLookup" class="btn btn-primary w-100">
                        <i class="bi bi-search me-2"></i>Search
                    </button>
                </div>
            </div>
            <div class="mt-3">
                <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    The system will verify the student is registered for the current session and term, and that payment items are configured for the selected category.
                </small>
            </div>
        </div>
    </div>

    <!-- Step 2: Student Info & Payment Items (populated by JS) -->
    <div id="paymentResultContainer" style="display:none;">
        <div class="card mb-4 mt-4" id="studentInfoCard">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-person-fill me-2"></i>Student Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3"><strong>Student:</strong> <span id="infoStudentName"></span></div>
                    <div class="col-md-2"><strong>Adm. No:</strong> <span id="infoAdmissionNo"></span></div>
                    <div class="col-md-3"><strong>Class:</strong> <span id="infoClassName"></span></div>
                    <div class="col-md-2"><strong>Session:</strong> <span id="infoSessionName"></span></div>
                    <div class="col-md-2"><strong>Term:</strong> <span id="infoTermName"></span></div>
                </div>
            </div>
        </div>

        <div id="paymentItemsContainer">
            <!-- Category cards injected by JS -->
        </div>

        <!-- Total & Submit -->
        <div class="card border-primary mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">
                        Total Selected: <span id="totalAmount" class="text-primary fw-bold">₦0.00</span>
                    </h4>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label for="paymentNarration" class="form-label">Narration <small class="text-muted">(optional, max 120 chars)</small></label>
                        <input type="text" id="paymentNarration" class="form-control" maxlength="120" placeholder="Payment narration..." />
                    </div>
                    <div class="col-md-6" id="evidenceUploadSection" style="display:none;">
                        <label for="paymentEvidence" class="form-label">
                            Payment Evidence <span class="text-danger">*</span>
                        </label>
                        <input type="file" id="paymentEvidence" class="form-control" accept=".jpg,.jpeg,.png,.pdf" />
                        <small class="text-muted">Accepted: JPG, JPEG, PNG, PDF (max 10MB)</small>
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="button" id="btnSubmitPayment" class="btn btn-success btn-lg" disabled>
                        <i class="bi bi-check-circle me-2"></i>Submit Payment
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/lib/jquery.blockui/jquery.blockui.js"></script>
    <partial name="_DatatablesScriptsFiles" />
    <script>
        window.userPermissions = {
            canCreate: @(Permissions.CanCreate ? "true" : "false"),
            canEdit: @(Permissions.CanEdit ? "true" : "false"),
            canDelete: @(Permissions.CanDelete ? "true" : "false")
        };
        window.evidenceRequired = @(Model.EvidenceRequired ? "true" : "false");
    </script>
    <script src="~/js/appmain.js"></script>
}
