@page "{termRegId:int}"
@model GrahamSchoolAdminSystemWeb.Pages.admin.student_payments.full_receiptModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Receipt - @Model.Receipt?.StudentName</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #222;
            background: #f4f4f4;
            padding: 1rem;
        }

        .receipt-page {
            max-width: 780px;
            margin: 0 auto;
            background: #fff;
            border: 1px solid #ccc;
            padding: 2rem 2.5rem;
        }

        /* ── Header ── */
        .receipt-top {
            display: flex;
            align-items: center;
            gap: 1.25rem;
            border-bottom: 3px double #333;
            padding-bottom: 1rem;
            margin-bottom: 1.5rem;
        }
        .receipt-top img {
            width: 80px;
            height: 80px;
            object-fit: contain;
        }
        .receipt-top .school-info { flex: 1; text-align: center; }
        .receipt-top .school-info h1 {
            font-size: 1.5rem;
            margin-bottom: .15rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .receipt-top .school-info p {
            font-size: .85rem;
            color: #555;
            margin-bottom: .1rem;
        }
        .receipt-top .school-info .receipt-label {
            display: inline-block;
            margin-top: .5rem;
            font-size: 1rem;
            font-weight: 700;
            color: #1a6e33;
            border: 2px solid #1a6e33;
            padding: .15rem .75rem;
            border-radius: 3px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        /* ── Student Info Grid ── */
        .student-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .35rem 2rem;
            margin-bottom: 1.5rem;
            font-size: .9rem;
        }
        .student-info .info-row {
            display: flex;
            gap: .5rem;
        }
        .student-info .info-label { font-weight: 600; min-width: 110px; }

        /* ── Category Section ── */
        .category-section {
            margin-bottom: 1.25rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            overflow: hidden;
        }
        .category-header {
            background: #2c3e50;
            color: #fff;
            padding: .5rem 1rem;
            font-weight: 600;
            font-size: .95rem;
        }
        .category-table {
            width: 100%;
            border-collapse: collapse;
        }
        .category-table th,
        .category-table td {
            padding: .45rem 1rem;
            border-bottom: 1px solid #eee;
            font-size: .88rem;
        }
        .category-table th {
            background: #f8f9fa;
            font-weight: 600;
            text-align: left;
        }
        .category-table td.amount { text-align: right; font-variant-numeric: tabular-nums; }
        .category-table th.amount { text-align: right; }
        .category-subtotal {
            background: #eef5ee;
            font-weight: 700;
        }
        .category-subtotal td { border-bottom: none; }

        /* ── Grand Total ── */
        .grand-total-bar {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 1.5rem;
            margin-top: 1.25rem;
            padding: .75rem 1rem;
            background: #1a6e33;
            color: #fff;
            border-radius: 4px;
            font-size: 1.15rem;
            font-weight: 700;
        }

        /* ── Footer ── */
        .receipt-footer {
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px dashed #aaa;
            display: flex;
            justify-content: space-between;
            font-size: .8rem;
            color: #777;
        }

        /* ── Print Button ── */
        .no-print {
            text-align: center;
            margin-bottom: 1rem;
        }
        .btn-print {
            padding: .5rem 1.5rem;
            font-size: .95rem;
            font-weight: 600;
            color: #fff;
            background: #1a6e33;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        .btn-print:hover { background: #145524; }
        .btn-back {
            padding: .5rem 1.5rem;
            font-size: .95rem;
            font-weight: 600;
            color: #333;
            background: #e9ecef;
            border: 1px solid #ccc;
            border-radius: 4px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            margin-right: .5rem;
        }
        .btn-back:hover { background: #dee2e6; }

        @@media print {
            body { background: #fff; padding: 0; }
            .receipt-page { border: none; padding: 1rem; max-width: 100%; }
            .no-print { display: none !important; }
            .category-section { break-inside: avoid; }
        }
    </style>
</head>
<body>
@if (Model.Receipt != null)
{
    <div class="no-print">
        <a href="/admin/student-payments/index" class="btn-back">&larr; Back to Payments</a>
        <button class="btn-print" onclick="window.print()">🖨️ Print Receipt</button>
    </div>

    <div class="receipt-page">
        <!-- Header with Logo -->
        <div class="receipt-top">
            <img src="/images/glogo2.png" alt="School Logo" />
            <div class="school-info">
                <h1>Graham International School, Gboko</h1>
                <p>Excellence in Education</p>
                <span class="receipt-label">Consolidated Payment Receipt</span>
            </div>
            <img src="/images/glogo2.png" alt="School Logo" style="visibility: hidden;" />
        </div>

        <!-- Student Info -->
        <div class="student-info">
            <div class="info-row">
                <span class="info-label">Student Name:</span>
                <span>@Model.Receipt.StudentName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Admission No:</span>
                <span>@Model.Receipt.AdmissionNo</span>
            </div>
            <div class="info-row">
                <span class="info-label">Class:</span>
                <span>@Model.Receipt.ClassName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Session:</span>
                <span>@Model.Receipt.SessionName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Term:</span>
                <span>@Model.Receipt.TermName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Print Date:</span>
                <span>@Model.Receipt.PrintDate.ToString("dd/MM/yyyy hh:mm tt")</span>
            </div>
        </div>

        <!-- Category Sections -->
        @{ int sn = 0; }
        @foreach (var category in Model.Receipt.Categories)
        {
            <div class="category-section">
                <div class="category-header">
                    @category.CategoryName
                    @if (category.PaymentReferences.Any())
                    {
                        <span style="font-weight:400; font-size:.82rem; margin-left:.75rem; opacity:.85;">
                            (Ref: @string.Join(", ", category.PaymentReferences))
                        </span>
                    }
                </div>
                <table class="category-table">
                    <thead>
                        <tr>
                            <th style="width:50px;">#</th>
                            <th>Payment Item</th>
                            <th class="amount" style="width:160px;">Amount Paid</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in category.Items)
                        {
                            sn++;
                            <tr>
                                <td>@sn</td>
                                <td>@item.ItemName</td>
                                <td class="amount">@GrahamSchoolAdminSystemAccess.SD.ToNaira(item.AmountPaid)</td>
                            </tr>
                        }
                        <tr class="category-subtotal">
                            <td colspan="2" style="text-align:right;">@category.CategoryName Subtotal:</td>
                            <td class="amount">@GrahamSchoolAdminSystemAccess.SD.ToNaira(category.CategoryTotal)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        <!-- Grand Total -->
        <div class="grand-total-bar">
            <span>Grand Total:</span>
            <span>@GrahamSchoolAdminSystemAccess.SD.ToNaira(Model.Receipt.GrandTotal)</span>
        </div>

        <!-- Footer -->
        <div class="receipt-footer">
            <span>This is a computer-generated receipt. No signature required.</span>
            <span>Printed: @Model.Receipt.PrintDate.ToString("dd/MM/yyyy hh:mm tt")</span>
        </div>
    </div>
}
else
{
    <div style="max-width:600px;margin:2rem auto;padding:1rem;background:#f8d7da;color:#842029;border-radius:4px;text-align:center;">
        Receipt data not found.
    </div>
}
</body>
</html>
