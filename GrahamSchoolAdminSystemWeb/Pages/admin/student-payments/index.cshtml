@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.student_payments.indexModel
@inject GrahamSchoolAdminSystemWeb.Helpers.ViewPermissionService Permissions
@{
    ViewData["Title"] = "Student Payments";
    await Permissions.InitializeAsync(User);
}

@section Sheets{
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <link href="~/lib/sweetalert2/sweetalert2.css" rel="stylesheet" />
    <partial name="_DataTablesSheetFiles" />
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-cash-stack"></i> Student Payments
        </h1>
        <p class="text-white">View all student payment transactions</p>
    </div>
    <div class="header-actions">
        @if (Permissions.CanCreate)
        {
            <a asp-page="/admin/student-payments/make-payment" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>New Payment
            </a>
        }
    </div>
</div>

<div class="page-content">
    <div class="row g-2 mb-2">
        <div class="col-md-4">
            <label for="paymentSearchInput">Search:</label>
            <input type="text" id="paymentSearchInput" class="form-control" placeholder="Search by reference or student name...">
        </div>
        <div class="col-md-2">
            <label for="filterSession">Session:</label>
            <select id="filterSession" class="form-select">
                <option value="">All Sessions</option>
            </select>
        </div>
        <div class="col-md-2">
            <label for="filterTerm">Term:</label>
            <select id="filterTerm" class="form-select">
                <option value="">All Terms</option>
                <option value="1">First Term</option>
                <option value="2">Second Term</option>
                <option value="3">Third Term</option>
            </select>
        </div>
        <div class="col-md-2">
            <label for="filterClass">Class:</label>
            <select id="filterClass" class="form-select">
                <option value="">All Classes</option>
            </select>
        </div>
        <div class="col-md-2">
            <label for="filterStatus">Status:</label>
            <select id="filterStatus" class="form-select">
                <option value="">All Status</option>
                <option value="Pending">Pending</option>
                <option value="Completed">Completed</option>
                <option value="Failed">Failed</option>
                <option value="Reversed">Reversed</option>
            </select>
        </div>
    </div>
    <div class="row g-2 mb-3">
        <div class="col-md-2">
            <label for="filterState">Payment State:</label>
            <select id="filterState" class="form-select">
                <option value="">All States</option>
                <option value="1">Pending</option>
                <option value="2">Approved</option>
                <option value="3">Rejected</option>
                <option value="4">Cancelled</option>
            </select>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class=" mt-3">
                <table id="studentPaymentsTable" class="table table-sm table-hover" width="100%" style="font-family:'Playfair Display', serif;">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Reference</th>
                            <th>Student</th>
                            <th>Admission No.</th>
                            <th>Class</th>
                            <th>Session</th>
                            <th>Term</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>State</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Receipt Modal -->
<div class="modal fade" id="receiptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Payment Receipt</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="receiptContent">
                <!-- Populated by JS -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="window.print()">
                    <i class="bi bi-printer me-2"></i>Print
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/lib/jquery.blockui/jquery.blockui.js"></script>
    <partial name="_DatatablesScriptsFiles" />
    <script>
        window.userPermissions = {
            canCreate: @(Permissions.CanCreate ? "true" : "false"),
            canEdit: @(Permissions.CanEdit ? "true" : "false"),
            canDelete: @(Permissions.CanDelete ? "true" : "false")
        };
    </script>
    <script src="~/js/appmain.js" asp-append-version="true"></script>
}
