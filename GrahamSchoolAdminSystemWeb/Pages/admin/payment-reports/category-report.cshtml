@page
@model GrahamSchoolAdminSystemWeb.Pages.admin.payment_reports.category_reportModel
@inject GrahamSchoolAdminSystemWeb.Helpers.ViewPermissionService Permissions
@{
    ViewData["Title"] = "Category & Item Report";
    await Permissions.InitializeAsync(User);
}

@section Sheets{
    <link rel="stylesheet" href="~/css/shared-components.css" />
    <link rel="stylesheet" href="~/css/admin-pages.css" />
    <partial name="_DataTablesSheetFiles" />
}

<div class="page-header">
    <div>
        <h1>
            <i class="bi bi-tags"></i> Category &amp; Item Report
        </h1>
        <p class="text-white">Revenue breakdown by payment item and category</p>
    </div>
</div>

<div class="page-content">
    <!-- Filters -->
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <label for="catRptSession">Session:</label>
            <select id="catRptSession" class="form-select">
                <option value="">-- Select Session --</option>
            </select>
        </div>
        <div class="col-md-2">
            <label for="catRptTerm">Term:</label>
            <select id="catRptTerm" class="form-select">
                <option value="">-- Select Term --</option>
                <option value="1">First Term</option>
                <option value="2">Second Term</option>
                <option value="3">Third Term</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="catRptCategory">Category:</label>
            <select id="catRptCategory" class="form-select">
                <option value="">All Categories</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="catRptClass">Class:</label>
            <select id="catRptClass" class="form-select">
                <option value="">All Classes</option>
            </select>
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button id="btnLoadCategoryReport" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i> Go
            </button>
        </div>
    </div>

    <!-- Summary Cards -->
    <div id="catReportSummary" class="row g-3 mb-3" style="display:none;">
        <div class="col-md-4">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Total Items</h6>
                    <h3 id="catSumItems" class="text-primary">0</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Students Paid</h6>
                    <h3 id="catSumStudentsPaid" class="text-success">0</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Total Collected</h6>
                    <h3 id="catSumCollected" class="text-info">₦0</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- DataTable -->
    <div class="datatable-container mt-3">
        <table id="categoryReportTable" class="table table-hover" style="width:100%">
            <thead>
                <tr>
                    <th>Payment Item</th>
                    <th>Category</th>
                    <th>Class</th>
                    <th>Total Students</th>
                    <th>Students Paid</th>
                    <th>Expected (₦)</th>
                    <th>Collected (₦)</th>
                    <th>Outstanding (₦)</th>
                </tr>
            </thead>
            <tbody></tbody>
            <tfoot>
                <tr class="table-dark fw-bold">
                    <th colspan="5" class="text-end">Grand Total:</th>
                    <th></th>
                    <th></th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_DatatablesScriptsFiles" />
    <script src="~/js/appmain.js"></script>
}
